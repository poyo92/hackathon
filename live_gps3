  const refLat=radiusCenter?radiusCenter.lat:(userLat||37.3382);
  const refLon=radiusCenter?radiusCenter.lon:(userLon||-121.8863);
  const radiusMi=radiusCenter?parseInt(document.getElementById('radiusSlider').value):null;
  const dests=getFiltered();
  if(!dests.length){list.innerHTML='<div class="nores">No destinations match this filter.</div>';return;}
  list.innerHTML='';

  // Section header if radius active
  if(radiusMi){
    const inCount=dests.filter(d=>d._dist<=radiusMi).length;
    if(inCount>0){
      const hdr=document.createElement('div');
      hdr.style.cssText='font-size:9px;text-transform:uppercase;letter-spacing:.1em;color:#d4a96a;font-weight:700;padding:4px 2px 6px';
      hdr.textContent=`Within ${radiusMi} mi (${inCount})`;
      list.appendChild(hdr);
    }
  }

  let shownOutHeader=false;
  dests.forEach(d=>{
    const dist=d._dist;
    const inRadius=radiusMi&&dist<=radiusMi;

    // Divider between in-radius and out-of-radius
    if(radiusMi&&!inRadius&&!shownOutHeader){
      shownOutHeader=true;
      const sep=document.createElement('div');
      sep.style.cssText='font-size:9px;text-transform:uppercase;letter-spacing:.1em;color:#9ca3af;font-weight:700;padding:10px 2px 6px;border-top:1px solid #e5e7eb;margin-top:4px';
      sep.textContent='Further away';
      list.appendChild(sep);
    }

    const el=document.createElement('div');
    el.className='dest-card'+(selectedDest&&selectedDest.id===d.id?' selected':'');
    const gemBadge=d.gem?'<span style="font-size:8px;background:#fef3c7;color:#92400e;padding:1px 6px;border-radius:8px;font-weight:600;margin-left:4px">💎 Hidden gem</span>':'';
