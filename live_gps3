/* Geodesically accurate great-circle polygon using the Haversine destination formula.
   For each bearing (0–360°) we compute the true lat/lon of a point exactly
   `radiusMiles` miles away from the center — so the rendered ring matches
   real-world distance regardless of latitude or zoom level. */
function destinationPoint(lat,lon,bearingDeg,distKm){
  const R=6371;
  const d=distKm/R; // angular distance in radians
  const b=bearingDeg*Math.PI/180;
  const lat1=lat*Math.PI/180;
  const lon1=lon*Math.PI/180;
  const lat2=Math.asin(Math.sin(lat1)*Math.cos(d)+Math.cos(lat1)*Math.sin(d)*Math.cos(b));
  const lon2=lon1+Math.atan2(Math.sin(b)*Math.sin(d)*Math.cos(lat1),Math.cos(d)-Math.sin(lat1)*Math.sin(lat2));
  return[lon2*180/Math.PI,lat2*180/Math.PI];
}

function buildCircleGeoJSON(lat,lon,radiusMiles){
  const km=radiusMiles*1.60934;
  const steps=128;
  const pts=[];
  for(let i=0;i<=steps;i++){
    pts.push(destinationPoint(lat,lon,(i/steps)*360,km));
  }
  return{type:'Feature',geometry:{type:'Polygon',coordinates:[pts]}};
}

function drawCircle(lat,lon,radiusMiles){
  const geojson=buildCircleGeoJSON(lat,lon,radiusMiles);
  if(map.getSource('radius-circle')){
    // Source already exists — just update the data, no flicker
    map.getSource('radius-circle').setData(geojson);
  }else{
    map.addSource('radius-circle',{type:'geojson',data:geojson});
    map.addLayer({id:'radius-fill',type:'fill',source:'radius-circle',paint:{'fill-color':'#d4a96a','fill-opacity':0.13}});
    map.addLayer({id:'radius-stroke',type:'line',source:'radius-circle',paint:{'line-color':'#d4a96a','line-width':2,'line-dasharray':[5,3]}});
  }
}

function onMapClickForRadius(e){
  if(!radiusMode)return;
  const {lng,lat}=e.lngLat;
  const miles=parseInt(document.getElementById('radiusSlider').value);
  radiusCenter={lat,lon:lng};
  drawCircle(lat,lng,miles);
  radiusMode=false;
  const btn=document.getElementById('radiusBtn');
  btn.textContent='Draw radius';btn.classList.remove('active');
  map.getCanvas().style.cursor='';
  document.getElementById('radiusClearBtn').style.display='';
  renderDestList(); // re-sort destinations by proximity to circle center
  fetchLocalIdeas(lat,lng,miles);
}

async function fetchLocalIdeas(lat,lon,miles){
  const panel=document.getElementById('radiusPanel');
  const body=document.getElementById('radiusPanelBody');
  const sub=document.getElementById('radiusPanelSub');
  panel.classList.add('open');
  body.innerHTML='<span class="spin"></span> Asking Claude for local ideas…';
  sub.textContent='';
  // Reverse geocode the clicked point
  let placeName='this area';
  try{
    const g=await geocode(lat,lon);
    if(g.label&&g.label!=='Unknown')placeName=g.label;
  }catch{}
  sub.textContent='· '+miles+' mi around '+placeName;
  const wx=currentWeather;
  const wxStr=wx.temp?`Current weather: ${wx.temp}°F, ${wdesc(wx.code||0)}, wind ${wx.wind}mph.`:'';
  const prompt=`The user is exploring a ${miles}-mile radius around ${placeName} (${lat.toFixed(3)},${lon.toFixed(3)}).
${wxStr}
Suggest local things to do, see, eat, and experience within ${miles} miles of ${placeName}.
Return ONLY valid JSON (no markdown, no backticks) in this exact shape:
{"place":"${placeName}","categories":[{"title":"🍽 Eat & Drink","ideas":["idea 1","idea 2","idea 3"]},{"title":"🏞 Outdoors & Nature","ideas":["idea 1","idea 2","idea 3"]},{"title":"🏛 Culture & Sights","ideas":["idea 1","idea 2","idea 3"]},{"title":"✨ Hidden Gems","ideas":["idea 1","idea 2"]}]}
Use real, specific places or types of places known to exist near ${placeName}. Be concise (max 12 words per idea).`;
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:800,system:'You are a knowledgeable local travel guide. Return ONLY valid JSON, no markdown, no backticks, no preamble.',messages:[{role:'user',content:prompt}]})});
    const data=await res.json();
    const raw=data.content?.filter(b=>b.type==='text').map(b=>b.text).join('')||'{}';
    const clean=raw.replace(/```json|```/g,'').trim();
    const parsed=JSON.parse(clean);
    let html='';
    (parsed.categories||[]).forEach(cat=>{
      html+=`<div class="radius-cat"><div class="radius-cat-title">${cat.title}</div>`;
      (cat.ideas||[]).forEach(idea=>{html+=`<div class="radius-idea">${idea}</div>`;});
      html+='</div>';
    });
    body.innerHTML=html||'<span class="ghost">No ideas returned. Try again.</span>';
  }catch(err){
    body.innerHTML=`<b>Local picks near ${placeName}:</b><br>Try restaurants, parks, museums, and local markets within ${miles} miles. Adjust the radius and click again for AI suggestions.`;
  }
}

