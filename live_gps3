  if(currentWeather.temp){
    sub.textContent=`For ${currentWeather.temp||'?'}°F, ${wdesc(currentWeather.code||0)} in ${currentWeather.name||'your area'}`;
  }
  const sorted=[...DESTINATIONS].sort((a,b)=>(weatherScores[b.id]||50)-(weatherScores[a.id]||50));
