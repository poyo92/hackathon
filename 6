    ()=>{setStatus('Location denied — defaulting to San Jose, CA','');userLat=37.3382;userLon=-121.8863;startTracking();},
    {enableHighAccuracy:true,timeout:10000}
  );
}else{
  setStatus('Geolocation unavailable','err');
