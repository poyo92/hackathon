    const cls=score>=75?'best':score>=55?'':'';
    const badgeCls=score>=75?'wmbadge-best':score>=55?'wmbadge-good':'wmbadge-fair';
    const badgeLbl=score>=75?'Top pick':score>=55?'Good fit':'Fair';
