  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:400,system:'You are a destination travel expert. Give a short, practical bullet list of top activities. Use • for bullets. Be specific and inspiring. Plain text only.',messages:[{role:'user',content:prompt}]})});
