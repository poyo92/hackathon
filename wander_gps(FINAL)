/* ═══════════════════════════════
   WEATHER SCORING
═══════════════════════════════ */
function scoreDestinations(){
  if(!currentWeather.temp)return;
  const {temp,wind,hum,code}=currentWeather;
  const isRainy=[51,53,55,61,63,65,80,81,82,95,96,99].includes(code);
  const isCold=temp<50;
  const isHot=temp>85;
  const refLat=userLat||37.3382, refLon=userLon||-121.8863;
  const allDists=DESTINATIONS.map(d=>haversineMi(refLat,refLon,d.lat,d.lon));
  const maxDist=Math.max(...allDists)||1;
  DESTINATIONS.forEach((d,i)=>{
    let score=60;
    const tags=d.tags;
    if(isCold){if(tags.includes('beach')||tags.includes('luxury'))score+=25;if(tags.includes('nature')&&!tags.includes('adventure'))score+=10;}
    if(isHot){if(tags.includes('adventure')&&d.climate==='Alpine')score+=20;if(tags.includes('nature')&&(d.country.includes('Canada')||d.country.includes('Iceland')))score+=20;}
    if(isRainy){if(tags.includes('culture')||tags.includes('city'))score+=20;if(tags.includes('food'))score+=15;}
    if(wind>20){if(tags.includes('beach'))score-=10;if(tags.includes('city'))score+=10;}
    score=Math.max(20,Math.min(99,score+Math.floor(Math.random()*10)));
    weatherScores[d.id]=score;
    const dist=allDists[i];
    distanceScores[d.id]={mi:Math.round(dist),bonus:Math.round((1-(dist/maxDist))*30)};
  });
}

