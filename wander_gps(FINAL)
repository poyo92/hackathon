async function startTracking(){
  setStatus('Fetching your location weather…','busy');
  ['aiBtn','refreshBtn'].forEach(id=>document.getElementById(id).disabled=true);
  try{
    const [wx,geo]=await Promise.all([fetchWx(userLat,userLon),geocode(userLat,userLon)]);
    const locName=geo.label!=='Unknown'?geo.label:'Your location';
    renderWeather(wx,locName);
    initMap(userLat,userLon);
    document.getElementById('coordsText').textContent=Math.abs(userLat).toFixed(4)+'°'+(userLat>=0?'N':'S')+' '+Math.abs(userLon).toFixed(4)+'°'+(userLon>=0?'E':'W');
    setStatus('Live — '+locName,'');
    ['aiBtn','refreshBtn'].forEach(id=>document.getElementById(id).disabled=false);
    scoreDestinations();
    renderDestList();
    renderWeatherMatch();
    populateBudgetDestSelect();
  }catch(e){
