const WMO={0:'Clear sky',1:'Mainly clear',2:'Partly cloudy',3:'Overcast',45:'Fog',48:'Icy fog',51:'Light drizzle',53:'Drizzle',55:'Heavy drizzle',61:'Light rain',63:'Rain',65:'Heavy rain',71:'Light snow',73:'Snow',75:'Heavy snow',80:'Showers',81:'Heavy showers',82:'Violent showers',95:'Thunderstorm',96:'Thunderstorm+hail',99:'Thunderstorm+hail'};
const WICO={0:'☀️',1:'🌤️',2:'⛅',3:'☁️',45:'🌫️',48:'🌫️',51:'🌦️',53:'🌦️',55:'🌧️',61:'🌦️',63:'🌧️',65:'🌧️',71:'🌨️',73:'❄️',75:'❄️',80:'🌧️',81:'🌧️',82:'⛈️',95:'⛈️',96:'⛈️',99:'⛈️'};
const wico=c=>WICO[c]||'🌡️', wdesc=c=>WMO[c]||'Unknown';

async function fetchWx(lat,lon){
  const r=await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat.toFixed(4)}&longitude=${lon.toFixed(4)}&current=temperature_2m,relative_humidity_2m,apparent_temperature,weather_code,wind_speed_10m&temperature_unit=fahrenheit&wind_speed_unit=mph&timezone=auto`);
  if(!r.ok)throw new Error('wx');
  return r.json();
}

async function geocode(lat,lon){
  try{
    const r=await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat.toFixed(5)}&lon=${lon.toFixed(5)}&format=json&zoom=10`,{headers:{'Accept-Language':'en'}});
    const d=await r.json();const a=d.address||{};
    const city=a.city||a.town||a.village||a.municipality||a.suburb||'';
    if(!city)return{label:'Unknown'};
    const state=a.state_code||'';
    return{label:state?`${city}, ${state}`:city};
  }catch{return{label:'Unknown'};}
}

function renderWeather(wx,name){
  const c=wx.current;
  const temp=Math.round(c.temperature_2m),feel=Math.round(c.apparent_temperature);
  const hum=Math.round(c.relative_humidity_2m),wind=Math.round(c.wind_speed_10m);
  const code=c.weather_code;
  currentWeather={temp,feel,hum,wind,code,name};
  document.getElementById('weatherPanel').innerHTML=`
    <div class="loc-name">${name}</div>
    <div class="weather-hero">
      <div class="w-icon">${wico(code)}</div>
      <div><div class="w-temp">${temp}°F</div><div class="w-sub">Feels ${feel}°F · ${wdesc(code)}</div></div>
    </div>
    <div class="g2">
      <div class="tile"><div class="tl">Humidity</div><div class="tv">${hum}%</div></div>
      <div class="tile"><div class="tl">Wind</div><div class="tv">${wind} mph</div></div>
    </div>`;
}

