<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Vacation Idea Planner</title>
<link href="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;font-family:'Inter',sans-serif;background:#f7f3ee;color:#1c1c1e}
.app{display:flex;flex-direction:column;max-width:1200px;margin:0 auto;height:100vh;min-height:600px;background:#fff;box-shadow:0 4px 32px rgba(0,0,0,.1)}

/* TOPBAR */
.topbar{display:flex;align-items:center;gap:12px;padding:12px 20px;background:#1c1c1e;color:#fff;flex-shrink:0;z-index:20}
.topbar-logo{font-family:'Playfair Display',serif;font-size:18px;font-weight:600;letter-spacing:.01em;color:#fff}
.topbar-logo span{color:#d4a96a}
.dot{width:7px;height:7px;border-radius:50%;background:#34d399;flex-shrink:0}
.dot.busy{background:#fbbf24;animation:blink 1s infinite}
.dot.err{background:#f87171}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
#statusText{font-size:12px;font-weight:400;color:#a1a1aa}
#coordsText{margin-left:auto;font-size:11px;color:#71717a;font-family:'Courier New',monospace}

/* BODY */
.body{display:grid;grid-template-columns:280px 1fr 320px;flex:1;min-height:0;overflow:hidden}

/* LEFT PANEL */
.side{border-right:1px solid #e5e7eb;display:flex;flex-direction:column;overflow:hidden;background:#fafaf9}
.sec{padding:14px 15px;border-bottom:1px solid #e5e7eb;flex-shrink:0}
.stitle{font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:#9ca3af;font-weight:600;margin-bottom:10px}
.weather-hero{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.w-icon{font-size:32px;line-height:1}
.w-temp{font-family:'Playfair Display',serif;font-size:30px;font-weight:400;color:#1c1c1e}
.w-sub{font-size:11px;color:#6b7280;margin-top:2px}
.loc-name{font-size:13px;font-weight:600;color:#374151;margin-bottom:8px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.tile{background:#fff;border-radius:8px;padding:8px 10px;border:1px solid #e5e7eb}
.tl{font-size:9px;text-transform:uppercase;letter-spacing:.07em;color:#9ca3af}
.tv{font-size:13px;font-weight:500;font-family:'Courier New',monospace;margin-top:2px;color:#1c1c1e}

/* VIBES */
.vibe-chips{display:flex;flex-wrap:wrap;gap:5px;padding:12px 15px;border-bottom:1px solid #e5e7eb;flex-shrink:0}
.vchip{font-size:10px;padding:4px 10px;border-radius:20px;border:1px solid #e5e7eb;background:#fff;color:#374151;cursor:pointer;transition:all .15s;white-space:nowrap}
.vchip:hover{border-color:#9ca3af}
.vchip.on{background:#1c1c1e;color:#fff;border-color:#1c1c1e}

/* DESTINATION CARDS */
.dest-scroll{flex:1;overflow-y:auto;padding:10px 12px}
.dest-card{border:1px solid #e5e7eb;border-radius:10px;padding:10px 12px;margin-bottom:7px;cursor:pointer;transition:all .15s;background:#fff}
.dest-card:hover{border-color:#9ca3af;box-shadow:0 2px 8px rgba(0,0,0,.06)}
.dest-card.selected{border-color:#d4a96a;background:#fffbf5}
.dest-card.selected .dname{color:#b45309}
.dname{font-size:13px;font-weight:600;color:#1c1c1e;margin-bottom:3px}
.dcountry{font-size:10px;color:#9ca3af;text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px}
.dmeta{font-size:11px;color:#6b7280;line-height:1.5}
.dtags{display:flex;gap:4px;flex-wrap:wrap;margin-top:6px}
.dtag{font-size:9px;padding:2px 7px;border-radius:10px;font-weight:500}
.dtag-beach{background:#dbeafe;color:#1d4ed8}
.dtag-adventure{background:#dcfce7;color:#15803d}
.dtag-culture{background:#fef3c7;color:#92400e}
.dtag-city{background:#ede9fe;color:#5b21b6}
.dtag-nature{background:#d1fae5;color:#065f46}
.dtag-luxury{background:#fce7f3;color:#9d174d}
.dtag-food{background:#fee2e2;color:#991b1b}
.nores{font-size:12px;color:#9ca3af;font-style:italic;text-align:center;padding:24px 10px}
.ghost{color:#9ca3af;font-style:italic}

/* MAP */
.maincol{display:flex;flex-direction:column;min-height:0;border-right:1px solid #e5e7eb}
#map{flex:1;min-height:0}
.attr-bar{display:flex;align-items:center;justify-content:space-between;padding:6px 12px;background:#fff;border-top:1px solid #e5e7eb;flex-shrink:0;flex-wrap:wrap;gap:6px}
.legend{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.li{display:flex;align-items:center;gap:4px;font-size:10px;color:#6b7280}
.ld{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.attr-text{font-size:10px;color:#9ca3af}
.attr-text a{color:#6b7280;text-decoration:none}

/* BOTTOM AI PANEL */
.btmpanel{padding:12px 15px;border-top:1px solid #e5e7eb;flex-shrink:0;background:#fff}
.brow{display:flex;gap:7px;margin-bottom:8px}
button{font-family:'Inter',sans-serif;font-size:12px;font-weight:500;padding:7px 12px;border-radius:8px;border:1px solid #d1d5db;background:#fff;color:#374151;cursor:pointer;transition:all .15s;white-space:nowrap}
button:hover:not(:disabled){background:#f9fafb;border-color:#9ca3af}
button:disabled{opacity:.35;cursor:not-allowed}
.btn-primary{background:#1c1c1e;color:#fff;border-color:#1c1c1e}
.btn-primary:hover:not(:disabled){background:#2d2d30;border-color:#2d2d30}
.btn-gold{background:#d4a96a;color:#fff;border-color:#d4a96a}
.btn-gold:hover:not(:disabled){background:#c49558;border-color:#c49558}
.aibox{font-size:12px;color:#374151;line-height:1.7;padding:10px 12px;background:#fafaf9;border-radius:8px;border:1px solid #e5e7eb;min-height:44px}
.aibox b{color:#1c1c1e;font-weight:600}

/* RIGHT PANEL */
.rpanel{display:flex;flex-direction:column;overflow:hidden;background:#fff}
.rtabs{display:flex;border-bottom:1px solid #e5e7eb;flex-shrink:0;background:#fafaf9}
.rtab{flex:1;padding:10px 4px;font-size:10px;font-weight:600;color:#6b7280;cursor:pointer;text-align:center;border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap}
.rtab:hover{color:#374151;background:#f3f4f6}
.rtab.active{color:#1c1c1e;border-bottom-color:#d4a96a;background:#fff}
.tab-pane{display:none;flex-direction:column;flex:1;overflow:hidden}
.tab-pane.active{display:flex}

/* DETAIL TAB */
.detail-hero{padding:15px;border-bottom:1px solid #e5e7eb;flex-shrink:0}
.detail-empty{padding:24px 15px;font-size:12px;color:#9ca3af;text-align:center;font-style:italic}
.detail-name{font-family:'Playfair Display',serif;font-size:19px;font-weight:600;color:#1c1c1e;margin-bottom:2px}
.detail-loc{font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.09em;margin-bottom:10px}
.detail-desc{font-size:12px;color:#4b5563;line-height:1.65;margin-bottom:12px}
.detail-stats{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:12px}
.dstat{background:#fafaf9;border-radius:8px;padding:8px 10px;border:1px solid #e5e7eb}
.dstat-lbl{font-size:9px;text-transform:uppercase;letter-spacing:.09em;color:#9ca3af;margin-bottom:2px}
.dstat-val{font-size:13px;font-weight:600;color:#1c1c1e}
.detail-score{display:flex;align-items:center;gap:6px;margin-bottom:12px}
.score-bar{flex:1;height:5px;background:#e5e7eb;border-radius:3px;overflow:hidden}
.score-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,#d4a96a,#b45309)}
.score-lbl{font-size:11px;font-weight:600;color:#92400e}
.detail-actions{display:flex;gap:6px;flex-wrap:wrap}
.detail-ai{padding:12px 15px;border-top:1px solid #e5e7eb;flex-shrink:0}
.aiinner{font-size:12px;color:#374151;line-height:1.65;padding:10px 12px;background:#fafaf9;border-radius:8px;border:1px solid #e5e7eb;min-height:42px;max-height:140px;overflow-y:auto}
.aiinner b{color:#1c1c1e;font-weight:600}

/* ITINERARY TAB */
.itin-header{padding:12px 15px;border-bottom:1px solid #e5e7eb;flex-shrink:0;display:flex;align-items:center;justify-content:space-between}
.itin-scroll{flex:1;overflow-y:auto;padding:10px 12px}
.itin-card{border:1px solid #e5e7eb;border-radius:10px;padding:10px 12px;margin-bottom:7px;background:#fff;display:flex;align-items:flex-start;gap:10px}
.itin-num{width:24px;height:24px;border-radius:50%;background:#1c1c1e;color:#fff;font-size:11px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
.itin-body{flex:1;min-width:0}
.itin-name{font-size:12px;font-weight:600;color:#1c1c1e;margin-bottom:2px}
.itin-meta{font-size:11px;color:#6b7280}
.itin-remove{cursor:pointer;color:#d1d5db;font-size:16px;line-height:1;flex-shrink:0;padding:2px 4px;border-radius:4px}
.itin-remove:hover{color:#f87171;background:#fef2f2}
.itin-empty{font-size:12px;color:#9ca3af;text-align:center;padding:32px 15px;font-style:italic;line-height:1.7}
.itin-footer{padding:12px 15px;border-top:1px solid #e5e7eb;flex-shrink:0}
.itin-plan-btn{width:100%;padding:10px;font-size:12px;font-weight:600;border-radius:8px;border:none;background:#1c1c1e;color:#fff;cursor:pointer;font-family:'Inter',sans-serif;transition:opacity .15s}
.itin-plan-btn:hover{opacity:.82}
.itin-plan-btn:disabled{opacity:.3;cursor:not-allowed}

/* WEATHER MATCH TAB */
.wm-header{padding:12px 15px;border-bottom:1px solid #e5e7eb;flex-shrink:0}
.wm-scroll{flex:1;overflow-y:auto;padding:10px 12px}
.wm-card{border:1px solid #e5e7eb;border-radius:10px;padding:10px 12px;margin-bottom:7px;cursor:pointer;background:#fff;transition:all .15s}
.wm-card:hover{border-color:#d4a96a;background:#fffbf5}
.wm-card.best{border-color:#34d399;background:#f0fdf4}
.wm-top{display:flex;justify-content:space-between;align-items:flex-start;gap:6px;margin-bottom:3px}
.wm-name{font-size:12px;font-weight:600;color:#1c1c1e}
.wmbadge{font-size:9px;padding:2px 7px;border-radius:8px;font-weight:600}
.wmbadge-best{background:#dcfce7;color:#15803d}
.wmbadge-good{background:#dbeafe;color:#1d4ed8}
.wmbadge-fair{background:#fef3c7;color:#92400e}
.wm-sub{font-size:11px;color:#6b7280}
.wm-bar{height:3px;background:#e5e7eb;border-radius:2px;margin-top:6px;overflow:hidden}
.wm-fill{height:100%;border-radius:2px;transition:width .5s}

@keyframes spin{to{transform:rotate(360deg)}}
.spin{display:inline-block;width:11px;height:11px;border:1.5px solid #d1d5db;border-top-color:#6b7280;border-radius:50%;animation:spin .6s linear infinite;vertical-align:middle;margin-right:5px}
.maplibregl-popup-content{font-family:'Inter',sans-serif;font-size:12px;padding:10px 12px;border-radius:8px;min-width:160px;max-width:240px;line-height:1.5}
.maplibregl-popup-content b{font-size:13px;display:block;margin-bottom:3px}
.pmeta-popup{font-size:11px;color:#6b7280;margin-top:2px}
@media(max-width:900px){.body{grid-template-columns:1fr}.side,.maincol{border-right:none;border-bottom:1px solid #e5e7eb}.rpanel{max-height:400px}}

/* ── RADIUS PLUGIN ── */
.radius-toolbar{display:flex;align-items:center;gap:6px;padding:8px 12px;background:#fffbf5;border-top:1px solid #e5e7eb;flex-shrink:0;flex-wrap:wrap}
.radius-toolbar label{font-size:11px;color:#6b7280;white-space:nowrap}
#radiusSlider{flex:1;min-width:80px;max-width:160px;accent-color:#d4a96a;cursor:pointer}
#radiusVal{font-size:11px;font-weight:600;color:#b45309;min-width:52px;font-family:'Courier New',monospace}
.btn-radius{background:#d4a96a;color:#fff;border:none;font-size:11px;padding:6px 11px;border-radius:7px;cursor:pointer;font-weight:600;transition:opacity .15s;white-space:nowrap}
.btn-radius:hover{opacity:.82}
.btn-radius.active{background:#1c1c1e}
.btn-radius:disabled{opacity:.35;cursor:not-allowed}

/* RADIUS RESULTS PANEL */
.radius-panel{position:absolute;bottom:130px;left:50%;transform:translateX(-50%);width:min(460px,90vw);background:#fff;border:1px solid #d4a96a;border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,.15);z-index:100;display:none;flex-direction:column;max-height:320px}
.radius-panel.open{display:flex}
.radius-panel-head{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-bottom:1px solid #e5e7eb;flex-shrink:0}
.radius-panel-title{font-size:13px;font-weight:600;color:#1c1c1e}
.radius-panel-close{cursor:pointer;font-size:18px;color:#9ca3af;line-height:1;padding:2px 5px;border-radius:4px;border:none;background:none}
.radius-panel-close:hover{color:#f87171;background:#fef2f2}
.radius-panel-body{padding:12px 14px;overflow-y:auto;font-size:12px;color:#374151;line-height:1.7}
.radius-panel-body b{color:#1c1c1e}
.radius-cat{margin-bottom:10px}
.radius-cat-title{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:#d4a96a;font-weight:700;margin-bottom:4px}
.radius-idea{padding:5px 8px;background:#fafaf9;border-radius:6px;margin-bottom:3px;border-left:3px solid #d4a96a;font-size:12px}

/* ══════════════════════════════
   BUDGET TAB STYLES
══════════════════════════════ */
.budget-tab-inner{flex:1;overflow-y:auto;display:flex;flex-direction:column}

/* Top controls */
.budget-controls{padding:12px 15px;border-bottom:1px solid #e5e7eb;flex-shrink:0;background:#fafaf9}
.budget-controls-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:8px}
.budget-controls-row:last-child{margin-bottom:0}
.budget-label{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:#9ca3af;font-weight:600;white-space:nowrap}

/* Traveler type pills */
.tpill{font-size:10px;padding:4px 10px;border-radius:16px;border:1px solid #e5e7eb;background:#fff;color:#374151;cursor:pointer;transition:all .15s;white-space:nowrap}
.tpill:hover{border-color:#9ca3af}
.tpill.on{background:#1c1c1e;color:#fff;border-color:#1c1c1e}

/* Duration input */
.dur-input{width:52px;padding:4px 7px;border:1px solid #e5e7eb;border-radius:8px;font-size:12px;font-family:'Inter',sans-serif;color:#1c1c1e;background:#fff;text-align:center}
.dur-input:focus{outline:none;border-color:#d4a96a}

/* Destination selector for budget */
.budget-dest-selector{width:100%;padding:6px 8px;border:1px solid #e5e7eb;border-radius:8px;font-size:11px;font-family:'Inter',sans-serif;color:#1c1c1e;background:#fff;cursor:pointer}
.budget-dest-selector:focus{outline:none;border-color:#d4a96a}

/* Generate button */
.budget-gen-btn{width:100%;padding:9px;font-size:12px;font-weight:600;border-radius:8px;border:none;background:linear-gradient(135deg,#d4a96a,#b45309);color:#fff;cursor:pointer;font-family:'Inter',sans-serif;transition:opacity .15s;margin-top:2px}
.budget-gen-btn:hover{opacity:.85}
.budget-gen-btn:disabled{opacity:.35;cursor:not-allowed}

/* Budget result area */
.budget-result{flex:1;overflow-y:auto;padding:12px 15px}

/* Summary card */
.budget-summary{background:linear-gradient(135deg,#1c1c1e,#2d2d30);border-radius:12px;padding:14px;margin-bottom:12px;color:#fff}
.budget-summary-dest{font-family:'Playfair Display',serif;font-size:16px;font-weight:600;margin-bottom:4px}
.budget-summary-meta{font-size:10px;color:#a1a1aa;margin-bottom:10px}
.budget-total-row{display:flex;justify-content:space-between;align-items:flex-end}
.budget-total-label{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:#71717a}
.budget-total-value{font-family:'Playfair Display',serif;font-size:26px;font-weight:600;color:#d4a96a}
.budget-total-sub{font-size:10px;color:#9ca3af;margin-top:2px}

/* Category breakdown */
.budget-category{border:1px solid #e5e7eb;border-radius:10px;padding:10px 12px;margin-bottom:7px;background:#fff}
.budget-cat-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px}
.budget-cat-name{font-size:11px;font-weight:600;color:#1c1c1e;display:flex;align-items:center;gap:5px}
.budget-cat-total{font-size:12px;font-weight:700;color:#1c1c1e}
.budget-cat-bar{height:4px;background:#f1f5f9;border-radius:2px;margin-bottom:8px;overflow:hidden}
.budget-cat-fill{height:100%;border-radius:2px;transition:width .8s cubic-bezier(.4,0,.2,1)}
.budget-items{display:flex;flex-direction:column;gap:3px}
.budget-item{display:flex;justify-content:space-between;align-items:center;font-size:11px;color:#4b5563;padding:3px 0;border-bottom:1px solid #f3f4f6}
.budget-item:last-child{border-bottom:none}
.budget-item-name{color:#6b7280}
.budget-item-range{font-weight:600;color:#374151;font-family:'Courier New',monospace;font-size:10px}

/* Tips section */
.budget-tips{background:#fffbf5;border:1px solid #fde68a;border-radius:10px;padding:11px 13px;margin-top:4px}
.budget-tips-title{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:#d4a96a;font-weight:700;margin-bottom:7px}
.budget-tip{font-size:11px;color:#4b5563;line-height:1.55;padding:3px 0;border-bottom:1px solid #fef3c7;display:flex;gap:6px}
.budget-tip:last-child{border-bottom:none}

/* Cost index badge */
.cost-index{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:12px;font-size:10px;font-weight:600}
.ci-budget{background:#dcfce7;color:#15803d}
.ci-moderate{background:#dbeafe;color:#1d4ed8}
.ci-expensive{background:#fef3c7;color:#92400e}
.ci-luxury{background:#fce7f3;color:#9d174d}

/* Empty state */
.budget-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;flex:1;padding:32px 20px;text-align:center;gap:10px}
.budget-empty-icon{font-size:36px;opacity:.5}
.budget-empty-text{font-size:12px;color:#9ca3af;line-height:1.7}

/* Loading skeleton */
.budget-skeleton{padding:12px 15px}
.skel{background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:8px;margin-bottom:8px}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

/* Transport card */
.budget-transport-card{border:1px solid #fde68a;border-radius:10px;padding:11px 13px;margin-bottom:10px;background:#fffbf5}
.budget-transport-header{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:4px}

</style>
</head>
<body>

<div class="app">
  <div class="topbar">
    <div class="dot busy" id="dot"></div>
    <div class="topbar-logo">wander<span>·ai</span></div>
    <span id="statusText">Getting your location…</span>
    <span id="coordsText">—</span>
  </div>

  <div class="body">

    <!-- LEFT: weather + destination browser -->
    <div class="side">
      <div class="sec">
        <div class="stitle">Your conditions</div>
        <div id="weatherPanel"><span class="ghost" style="font-size:12px">Waiting for GPS…</span></div>
      </div>
      <div class="vibe-chips" id="vibeChips">
        <span class="vchip on" onclick="setVibe('all',this)">All</span>
        <span class="vchip" onclick="setVibe('beach',this)">🏖 Beach</span>
        <span class="vchip" onclick="setVibe('adventure',this)">🧗 Adventure</span>
        <span class="vchip" onclick="setVibe('culture',this)">🏛 Culture</span>
        <span class="vchip" onclick="setVibe('city',this)">🌆 City</span>
        <span class="vchip" onclick="setVibe('nature',this)">🌿 Nature</span>
        <span class="vchip" onclick="setVibe('luxury',this)">✨ Luxury</span>
        <span class="vchip" onclick="setVibe('food',this)">🍜 Food</span>
      </div>
      <div class="dest-scroll" id="destList">
        <div class="nores">Loading destinations…</div>
      </div>
    </div>

    <!-- CENTER: map -->
    <div class="maincol" style="position:relative">
      <div id="map"></div>

      <!-- Floating radius results panel -->
      <div class="radius-panel" id="radiusPanel">
        <div class="radius-panel-head">
          <div class="radius-panel-title">📍 Local Area Ideas <span id="radiusPanelSub" style="font-size:10px;color:#9ca3af;font-weight:400"></span></div>
          <button class="radius-panel-close" onclick="closeRadiusPanel()">×</button>
        </div>
        <div class="radius-panel-body" id="radiusPanelBody"><span class="ghost">Generating ideas…</span></div>
      </div>

      <div class="attr-bar">
        <div class="legend">
          <div class="li"><div class="ld" style="background:#1d4ed8"></div>Beach</div>
          <div class="li"><div class="ld" style="background:#15803d"></div>Nature</div>
