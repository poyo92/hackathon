};

/* ── TRANSPORT COST MODEL ──────────────────────────────────────────────
   Based on published IATA average yield data ($/RPK) and open GDS
   fare studies. Flight cost = base_fare + (dist_km × yield_per_km).
   Ground transport modeled from national rail/bus pricing surveys.
──────────────────────────────────────────────────────────────────────── */
function calcTransportCost(distKm, mode) {
  if (mode === 'flight') {
    // IATA Economy yield: ~$0.10–0.14/km short-haul, ~$0.06–0.09/km long-haul
    // Base airport fees + taxes: ~$80–120
    const baseFee = 100;
    let yieldPerKm;
    if (distKm < 800)        yieldPerKm = 0.22;  // ultra short-haul premium
    else if (distKm < 2000)  yieldPerKm = 0.14;  // short-haul
    else if (distKm < 6000)  yieldPerKm = 0.09;  // medium-haul
    else                     yieldPerKm = 0.065; // long-haul
    const raw = baseFee + distKm * yieldPerKm;
    // Round-trip: ×2, with ~15% discount on return leg typical
    const rt = raw * 1.85;
    const variance = 0.35; // ±35% for sales/seasons
    return {
      mode: 'Flight ✈️',
      min: Math.round(rt * (1 - variance) / 10) * 10,
      max: Math.round(rt * (1 + variance) / 10) * 10,
      detail: `~${Math.round(distKm).toLocaleString()} km · economy RT`,
      time: distKm < 800 ? '< 2 hrs' : distKm < 2500 ? '2–6 hrs' : distKm < 8000 ? '6–13 hrs' : '13+ hrs',
      tip: distKm < 500
        ? 'Short hop — check Southwest, Alaska, or Spirit for flash sales. Book 3–5 weeks out.'
        : distKm < 3000
        ? 'Book 6–8 weeks ahead. Midweek departures save 10–20%. Google Flights price tracker recommended.'
        : 'Long-haul: book 3–5 months ahead. Check mistake fares on Secret Flying. Positioning flights via a hub can cut costs significantly.'
    };
  }
  if (mode === 'drive') {
    // IRS mileage rate basis + fuel cost model (avg US $3.80/gal, 30 mpg)
    const miles = distKm * 0.621371;
    const fuelCostPerMile = 3.80 / 30; // $0.127/mile
    const totalFuelRT = miles * 2 * fuelCostPerMile;
    const wearTear = miles * 2 * 0.05; // $0.05/mile wear
    const total = totalFuelRT + wearTear;
    return {
      mode: 'Drive 🚗',
      min: Math.round(total * 0.85 / 5) * 5,
      max: Math.round(total * 1.15 / 5) * 5,
      detail: `~${Math.round(miles)} miles each way`,
      time: miles < 100 ? '< 2 hrs' : miles < 300 ? '2–5 hrs' : miles < 600 ? '5–10 hrs' : '10+ hrs · consider overnight stop',
      tip: 'Factor in parking at the destination. Apps like GasBuddy help find cheapest fuel. Toll roads vary — check TollGuru.'
    };
  }
  if (mode === 'ferry') {
    // Ferry pricing: ~$0.06–0.12/km for foot passenger, typical routes
    const base = 18 + distKm * 0.09;
    return {
      mode: 'Ferry ⛴',
      min: Math.round(base * 0.7 / 5) * 5,
      max: Math.round(base * 1.4 / 5) * 5,
      detail: `Foot passenger RT · ~${Math.round(distKm)} km route`,
      time: distKm < 30 ? '< 45 min' : distKm < 100 ? '1–3 hrs' : '3–8 hrs',
      tip: 'Book ahead on peak weekends. Bike/vehicle surcharges apply separately. Off-peak crossings often 30% cheaper.'
    };
  }
  if (mode === 'train') {
    // National rail avg: US $0.18/km, Europe $0.12/km, Asia $0.08/km
    const base = 15 + distKm * 0.14;
    return {
      mode: 'Train 🚆',
      min: Math.round(base * 0.7 / 5) * 5,
      max: Math.round(base * 1.5 / 5) * 5,
      detail: `Economy class RT · ~${Math.round(distKm)} km`,
      time: distKm < 150 ? '1–3 hrs' : distKm < 500 ? '3–7 hrs' : '7+ hrs · overnight options',
      tip: 'Rail passes (Eurail, JR Pass, Amtrak Multi-Ride) often beat individual tickets. Book dynamic pricing routes early.'
    };
  }
  return null;
}

/* ── AUTO-DETECT TRANSPORT MODE from destination data ── */
function detectTransportMode(dest) {
  const distKm = haversineKm(userLat || 37.3382, userLon || -121.8863, dest.lat, dest.lon);
  const distMi = distKm * 0.621371;

  // Ferry destinations (island or coastal accessed by water)
  const ferryIds = [8, 11, 15, 72, 75, 104, 37, 48, 50];
  if (ferryIds.includes(dest.id) && distMi < 200) return { mode: 'ferry', distKm };

  // Very short — drive if < 250 miles
  if (distMi < 250) return { mode: 'drive', distKm };

  // Medium domestic — train if relevant (CA rail corridor)
  if (distMi < 500 && [97, 106, 73, 67, 98, 103, 101, 102].includes(dest.id)) {
    return { mode: 'train', distKm };
  }

  // Everything else: fly
  return { mode: 'flight', distKm };
}

/* ── OPEN DATA: fetch live USD exchange rate for a currency ── */
async function fetchExchangeRate(currency) {
  if (currency === 'USD') return 1;
  try {
    // exchangerate.host — open source, free, no API key
    const r = await fetch(`https://api.exchangerate.host/latest?base=USD&symbols=${currency}`);
    const d = await r.json();
    return d.rates?.[currency] || 1;
  } catch {
    return 1; // fallback: treat as USD
  }
}

