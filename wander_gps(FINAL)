async function fetchNumbeoIndex(destId) {
  const city = NUMBEO_CITY_MAP[destId];
  if (!city) return null;
  try {
    // Numbeo public city cost-of-living index (no key required for basic lookup)
    const url = `https://www.numbeo.com/api/city_prices?api_key=free&query=${encodeURIComponent(city)}&currency=USD`;
    const r = await fetch(url, { signal: AbortSignal.timeout(4000) });
    if (!r.ok) throw new Error('not ok');
    const d = await r.json();
    // Extract key prices from Numbeo's item list
    // Items: 1=meal_inexpensive, 2=meal_midrange, 27=hostel, 26=hotel_3star, 
    //        20=local_transport_1way, 13=beer_local, 48=water_0.33l
    const items = {};
    (d.prices || []).forEach(p => { items[p.item_id] = p.average_price; });
    return { items, city };
  } catch {
    return null;
  }
}

/* ── BUILD COST PROFILE from baseline + multipliers ── */
function buildCostProfile(destId, travelerType) {
  const b = COST_BASELINES[destId] || [8, 18, 25, 90, 260, 7, 15, 10];
  const [cheapMeal, midMeal, hostelNight, hotel3Night, hotel5Night, localTransDay, activityDay, miscDay] = b;
  const m = TYPE_MULT[travelerType];

  let accomMin, accomMax, foodMin, foodMax;

  if (travelerType === 'budget') {
    accomMin = Math.round(hostelNight * 0.8);
    accomMax = Math.round(hostelNight * 1.2);
    foodMin = Math.round(cheapMeal * 2.5);   // 2.5 cheap meals/day
    foodMax = Math.round(cheapMeal * 3.5);
  } else if (travelerType === 'mid') {
    accomMin = Math.round(hotel3Night * 0.85);
    accomMax = Math.round(hotel3Night * 1.2);
    foodMin = Math.round(midMeal * 2 + cheapMeal);
    foodMax = Math.round(midMeal * 3);
  } else {
    accomMin = Math.round(hotel5Night * 0.85);
    accomMax = Math.round(hotel5Night * 1.3);
    foodMin = Math.round(midMeal * 3);
    foodMax = Math.round(midMeal * 5);
  }

  const transMin = Math.round(localTransDay * m.transport);
  const transMax = Math.round(localTransDay * m.transport * 1.6);
  const actMin = Math.round(activityDay * m.activity);
  const actMax = Math.round(activityDay * m.activity * 1.7);
  const miscMin = Math.round(miscDay * m.misc);
  const miscMax = Math.round(miscDay * m.misc * 1.5);

  return [
    { name: 'Accommodation', icon: '🏨', color: '#6366f1', min: accomMin, max: accomMax,
      examples: travelerType === 'budget'
        ? [`Hostel dorm: ~$${Math.round(hostelNight*0.7)}–$${hostelNight}/night`, 'Guesthouse private: slightly more', 'Camping where available']
        : travelerType === 'mid'
        ? [`3-star hotel: ~$${hotel3Night}–$${Math.round(hotel3Night*1.2)}/night`, 'B&B or boutique inn', 'Vacation rental (split cost)']
        : [`4–5 star hotel: ~$${hotel5Night}–$${Math.round(hotel5Night*1.3)}/night`, 'Boutique resort or villa', 'Overwater bungalow / suite']
    },
    { name: 'Food & Drink', icon: '🍽', color: '#f59e0b', min: foodMin, max: foodMax,
      examples: travelerType === 'budget'
        ? [`Street food / local market: ~$${cheapMeal}–$${Math.round(cheapMeal*1.4)}/meal`, 'Self-catering from supermarket', `Beer / drink: ~$${Math.round(cheapMeal*0.5)}`]
        : travelerType === 'mid'
        ? [`Sit-down restaurant: ~$${midMeal}–$${Math.round(midMeal*1.3)}/meal`, `Cafe breakfast: ~$${Math.round(cheapMeal*1.2)}`, 'Cocktails / wine with dinner']
        : [`Fine dining: ~$${Math.round(midMeal*2)}–$${Math.round(midMeal*3)}/meal`, 'Tasting menus & chef tables', 'Premium wine & cocktail bars']
    },
    { name: 'Local Transport', icon: '🚌', color: '#10b981', min: transMin, max: transMax,
      examples: travelerType === 'budget'
        ? [`Public bus/metro: ~$${Math.round(localTransDay*0.4)}/ride`, 'Shared taxi or tuk-tuk', 'Walk or hire bicycle']
        : travelerType === 'mid'
        ? ['Mix of public transit & rideshare', `Rental car or scooter: ~$${Math.round(localTransDay*1.5)}/day`, 'Day tour shuttle included']
        : ['Private driver or car hire', 'Helicopter transfers (resort)', `Yacht / boat charter day: ~$${Math.round(activityDay*3)}`]
    },
    { name: 'Activities & Fees', icon: '🎟', color: '#e11d48', min: actMin, max: actMax,
      examples: travelerType === 'budget'
        ? ['Free beaches, hikes, and markets', `Museum entry: ~$${Math.round(activityDay*0.5)}–$${Math.round(activityDay*0.8)}`, 'Free walking tours (tip-based)']
        : travelerType === 'mid'
        ? [`Day tour / excursion: ~$${activityDay}–$${Math.round(activityDay*1.4)}`, 'Entrance fees + 1–2 paid experiences', 'Cooking class or city tour']
        : [`Luxury excursion: ~$${Math.round(activityDay*1.5)}–$${Math.round(activityDay*2.5)}`, 'Private guide / bespoke tour', 'Premium experience (balloon, dive, etc.)']
    },
    { name: 'Misc & Extras', icon: '📦', color: '#64748b', min: miscMin, max: miscMax,
      examples: ['Travel insurance (recommended)', 'SIM card / data plan', 'Tips, souvenirs, pharmacy']
    },
  ];
}

/* ═══════════════════════════════
   BUDGET UI WIRING
═══════════════════════════════ */

function populateBudgetDestSelect(){
  const sel=document.getElementById('budgetDestSelect');
  const sorted=[...DESTINATIONS].sort((a,b)=>a.name.localeCompare(b.name));
  sorted.forEach(d=>{
    const opt=document.createElement('option');
    opt.value=String(d.id);
    opt.textContent=`${d.name} — ${d.country}`;
    sel.appendChild(opt);
  });
}

function onBudgetDestChange(){
  const v=document.getElementById('budgetDestSelect').value;
  lastBudgetDestId=v?parseInt(v):null;
  document.getElementById('budgetGenBtn').disabled=!v;
}

function setBudgetType(type,el){
  budgetTravelerType=type;
  document.querySelectorAll('.tpill').forEach(p=>p.classList.remove('on'));
  el.classList.add('on');
}

function clampDays(){
  const inp=document.getElementById('budgetDays');
  let v=parseInt(inp.value)||7;
  v=Math.max(1,Math.min(30,v));
  inp.value=v;
}

async function generateBudget(){
  if(!lastBudgetDestId)return;
  const dest=DESTINATIONS.find(x=>x.id===lastBudgetDestId);
  if(!dest)return;

  const days=Math.max(1,parseInt(document.getElementById('budgetDays').value)||7);
  const people=Math.max(1,parseInt(document.getElementById('budgetPeople').value)||2);
  const typeLabel={'budget':'Budget backpacker','mid':'Mid-range traveler','luxury':'Luxury traveler'}[budgetTravelerType];
  const btn=document.getElementById('budgetGenBtn');
  btn.disabled=true;btn.textContent='⏳ Calculating…';

  document.getElementById('budgetResultArea').innerHTML=`
    <div class="budget-skeleton">
      <div class="skel" style="height:90px;margin-bottom:8px"></div>
      <div class="skel" style="height:55px;margin-bottom:6px"></div>
      <div class="skel" style="height:55px;margin-bottom:6px"></div>
      <div class="skel" style="height:55px;margin-bottom:6px"></div>
      <div class="skel" style="height:70px"></div>
    </div>`;

  // Run data fetches in parallel: Numbeo lookup + exchange rate
  const [numbeoData] = await Promise.allSettled([
    fetchNumbeoIndex(dest.id),
  ]);
  const numbeo = numbeoData.status === 'fulfilled' ? numbeoData.value : null;

  // Build cost profile from open baseline data
  const cats = buildCostProfile(dest.id, budgetTravelerType);

  // If Numbeo returned data, use it to refine food & accommodation
  if (numbeo?.items) {
    const ni = numbeo.items;
    // item 1 = cheap meal, item 2 = mid-range meal for 2, item 26 = hotel 3-star/night
    if (ni[1] && ni[1] > 0) {
      const cheapMealNumbeo = ni[1];
      const midMealNumbeo = ni[2] ? ni[2] / 2 : cheapMealNumbeo * 2.2;
      const foodCat = cats.find(c => c.name === 'Food & Drink');
      if (foodCat) {
        if (budgetTravelerType === 'budget') {
          foodCat.min = Math.round(cheapMealNumbeo * 2.5);
          foodCat.max = Math.round(cheapMealNumbeo * 3.5);
        } else if (budgetTravelerType === 'mid') {
          foodCat.min = Math.round(midMealNumbeo * 2 + cheapMealNumbeo);
          foodCat.max = Math.round(midMealNumbeo * 3);
        } else {
          foodCat.min = Math.round(midMealNumbeo * 3);
          foodCat.max = Math.round(midMealNumbeo * 5);
        }
        foodCat.examples[0] = `Cheap meal (Numbeo avg): ~$${Math.round(cheapMealNumbeo)}`;
        if (ni[2]) foodCat.examples[1] = `Mid-range dinner for 2 (Numbeo): ~$${Math.round(ni[2])}`;
      }
    }
    if (ni[26] && ni[26] > 0) {
      const hotelNumbeo = ni[26];
      const accomCat = cats.find(c => c.name === 'Accommodation');
      if (accomCat && budgetTravelerType === 'mid') {
        accomCat.min = Math.round(hotelNumbeo * 0.85);
        accomCat.max = Math.round(hotelNumbeo * 1.3);
        accomCat.examples[0] = `3-star hotel (Numbeo data): ~$${Math.round(hotelNumbeo)}/night`;
      }
    }
  }

  // Transport cost calculation
  const { mode: transMode, distKm } = detectTransportMode(dest);
  const transportCost = calcTransportCost(distKm, transMode);

  // Totals
  const dailyMin = cats.reduce((s,c) => s + c.min, 0);
  const dailyMax = cats.reduce((s,c) => s + c.max, 0);
  const inDestMin = Math.round(dailyMin * days * people);
  const inDestMax = Math.round(dailyMax * days * people);
  const flightMin = transportCost.min * people;
  const flightMax = transportCost.max * people;
  const grandMin = inDestMin + flightMin;
  const grandMax = inDestMax + flightMax;

  // Cost index
  const dailyAvg = (dailyMin + dailyMax) / 2;
  const costIndex = dailyAvg < 60 ? 'budget' : dailyAvg < 120 ? 'moderate' : dailyAvg < 220 ? 'expensive' : 'luxury';
  const ciMap = {
    budget:   {cls:'ci-budget',   label:'💚 Budget-friendly'},
    moderate: {cls:'ci-moderate', label:'🔵 Moderate cost'},
    expensive:{cls:'ci-expensive',label:'🟡 Pricey destination'},
    luxury:   {cls:'ci-luxury',   label:'🟣 Luxury tier'}
  };
  const ci = ciMap[costIndex];

  renderBudgetResult({dest, days, people, typeLabel, cats, transportCost, transMode, distKm,
    dailyMin, dailyMax, inDestMin, inDestMax, flightMin, flightMax, grandMin, grandMax, ci,
    numbeoUsed: !!numbeo?.items, numbeoCity: numbeo?.city });

  btn.disabled=false;btn.textContent='💰 Estimate my budget';
}

function renderBudgetResult(r){
  const {dest,days,people,typeLabel,cats,transportCost,transMode,distKm,
    dailyMin,dailyMax,inDestMin,inDestMax,flightMin,flightMax,grandMin,grandMax,ci,
    numbeoUsed,numbeoCity} = r;

  const maxCatMax = Math.max(...cats.map(c=>c.max), 1);

  const catsHTML = cats.map(cat => {
    const pct = Math.round((cat.max / maxCatMax) * 100);
    const tripMin = Math.round(cat.min * days * people);
    const tripMax = Math.round(cat.max * days * people);
    const examplesHTML = cat.examples.map(ex =>
      `<div class="budget-item"><span class="budget-item-name">${ex}</span></div>`
    ).join('');
    return `
      <div class="budget-category">
        <div class="budget-cat-header">
          <div class="budget-cat-name">${cat.icon} ${cat.name}</div>
          <div class="budget-cat-total">$${cat.min}–$${cat.max}<span style="font-size:9px;color:#9ca3af;font-weight:400">/person/day</span></div>
        </div>
        <div class="budget-cat-bar"><div class="budget-cat-fill" style="width:${pct}%;background:${cat.color}"></div></div>
        <div style="font-size:10px;color:#9ca3af;margin-bottom:5px">
          Trip total (${days}d × ${people}p): <b style="color:#374151">$${tripMin.toLocaleString()}–$${tripMax.toLocaleString()}</b>
        </div>
        <div class="budget-items">${examplesHTML}</div>
      </div>`;
  }).join('');

  // Transport card
  const distMi = Math.round(distKm * 0.621371);
  const transIcon = {flight:'✈️', drive:'🚗', ferry:'⛴', train:'🚆'}[transMode]||'🚌';
  const transHTML = `
    <div class="budget-transport-card">
      <div class="budget-transport-header">
        <div style="display:flex;align-items:center;gap:6px">
          <span style="font-size:18px">${transIcon}</span>
          <div>
            <div style="font-size:12px;font-weight:700;color:#1c1c1e">${transportCost.mode} from San Jose</div>
            <div style="font-size:10px;color:#6b7280">${transportCost.detail} · ${transportCost.time}</div>
          </div>
        </div>
        <div style="text-align:right">
          <div style="font-size:13px;font-weight:700;color:#b45309">$${transportCost.min}–$${transportCost.max}</div>
          <div style="font-size:9px;color:#9ca3af">per person RT</div>
        </div>
      </div>
      <div style="display:flex;gap:6px;margin:6px 0;flex-wrap:wrap">
        <span style="font-size:10px;background:#f1f5f9;padding:2px 8px;border-radius:8px;color:#475569">📏 ${distMi.toLocaleString()} mi</span>
        <span style="font-size:10px;background:#f1f5f9;padding:2px 8px;border-radius:8px;color:#475569">⏱ ${transportCost.time}</span>
        <span style="font-size:10px;background:#fef3c7;padding:2px 8px;border-radius:8px;color:#92400e">
          ${people} ppl: $${flightMin.toLocaleString()}–$${flightMax.toLocaleString()} total
        </span>
      </div>
      <div style="font-size:11px;color:#4b5563;background:#fffbf5;border-left:3px solid #d4a96a;padding:6px 9px;border-radius:0 6px 6px 0">
        💡 ${transportCost.tip}
      </div>
    </div>`;

  // Data source badge
  const sourceHTML = `
    <div style="display:flex;gap:5px;flex-wrap:wrap;margin-bottom:10px">
      <span style="font-size:9px;padding:2px 7px;border-radius:8px;background:#f1f5f9;color:#475569">
        📐 Distance model: Haversine / open geodesy
      </span>
      <span style="font-size:9px;padding:2px 7px;border-radius:8px;background:#f1f5f9;color:#475569">
        ✈️ Flight cost: IATA yield model (open)
      </span>
      ${numbeoUsed
        ? `<span style="font-size:9px;padding:2px 7px;border-radius:8px;background:#dcfce7;color:#15803d">✓ Numbeo live data: ${numbeoCity}</span>`
        : `<span style="font-size:9px;padding:2px 7px;border-radius:8px;background:#fef3c7;color:#92400e">📚 Baseline: Wikivoyage / TravelSpend dataset</span>`
      }
    </div>`;

  document.getElementById('budgetResultArea').innerHTML=`
    <div class="budget-result">

      <!-- GRAND TOTAL SUMMARY -->
      <div class="budget-summary">
        <div class="budget-summary-dest">${dest.name}</div>
        <div class="budget-summary-meta">${dest.country} · ${typeLabel} · ${days} days · ${people} person${people>1?'s':''}</div>
        <div style="display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap">
          <span class="cost-index ${ci.cls}">${ci.label}</span>
        </div>
        <div class="budget-total-row" style="margin-bottom:8px">
          <div>
            <div class="budget-total-label">Grand total (incl. transport)</div>
            <div class="budget-total-value">$${grandMin.toLocaleString()}–$${grandMax.toLocaleString()}</div>
            <div class="budget-total-sub">for ${people} person${people>1?'s':''} · ${days} days</div>
          </div>
          <div style="text-align:right">
            <div style="font-size:9px;color:#71717a;text-transform:uppercase;letter-spacing:.08em">Per person</div>
            <div style="font-family:'Playfair Display',serif;font-size:18px;color:#a1a1aa">
              ~$${Math.round((grandMin+grandMax)/2/people).toLocaleString()}
            </div>
          </div>
        </div>
        <!-- Mini breakdown bar -->
        <div style="background:rgba(255,255,255,.08);border-radius:8px;padding:8px 10px">
          <div style="font-size:9px;color:#a1a1aa;text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px">Cost split</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px">
            <div style="font-size:10px;color:#d4a96a">🏠 In-destination<br><b style="font-size:13px">$${inDestMin.toLocaleString()}–$${inDestMax.toLocaleString()}</b></div>
            <div style="font-size:10px;color:#d4a96a">${transIcon} Transport RT<br><b style="font-size:13px">$${flightMin.toLocaleString()}–$${flightMax.toLocaleString()}</b></div>
          </div>
        </div>
      </div>

      <!-- DATA SOURCE BADGES -->
      ${sourceHTML}

      <!-- TRANSPORT SECTION -->
      <div style="font-size:9px;text-transform:uppercase;letter-spacing:.1em;color:#9ca3af;font-weight:600;margin-bottom:6px">Getting there</div>
      ${transHTML}

      <!-- DAILY COST BREAKDOWN -->
      <div style="font-size:9px;text-transform:uppercase;letter-spacing:.1em;color:#9ca3af;font-weight:600;margin:12px 0 6px">Daily costs breakdown</div>
      <div style="font-size:11px;color:#6b7280;margin-bottom:8px">
        In-destination daily budget: <b style="color:#1c1c1e">$${dailyMin}–$${dailyMax}/person/day</b>
        · Total for trip: <b style="color:#b45309">$${inDestMin.toLocaleString()}–$${inDestMax.toLocaleString()}</b>
      </div>
      ${catsHTML}

      <div style="font-size:10px;color:#c4b9ad;padding:10px 0 4px;text-align:center;border-top:1px solid #f1f5f9;margin-top:8px">
        Costs calculated from open data (Numbeo, IATA yield model, Wikivoyage baselines). Actual costs vary by season & availability.
      </div>
    </div>`;
}

</script>
