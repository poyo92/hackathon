function getFiltered(){
  const refLat=radiusCenter?radiusCenter.lat:(userLat||37.3382);
  const refLon=radiusCenter?radiusCenter.lon:(userLon||-121.8863);
  const radiusMi=radiusCenter?parseInt(document.getElementById('radiusSlider').value):null;
  let dests=activeVibe==='all'?[...DESTINATIONS]:DESTINATIONS.filter(d=>d.tags.includes(activeVibe));
  dests=dests.map(d=>({...d,_dist:haversineMi(refLat,refLon,d.lat,d.lon)}))
    .sort((a,b)=>{
      if(radiusMi){
        const aIn=a._dist<=radiusMi, bIn=b._dist<=radiusMi;
        if(aIn&&!bIn)return -1;
        if(!aIn&&bIn)return 1;
      }
      return a._dist-b._dist;
    });
  return dests;
}

