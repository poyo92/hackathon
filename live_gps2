<script src="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js"></script>
<script>
/* в”Җв”Җ constants в”Җв”Җ */
const WMO={0:'Clear sky',1:'Mainly clear',2:'Partly cloudy',3:'Overcast',45:'Fog',48:'Icy fog',51:'Light drizzle',53:'Drizzle',55:'Heavy drizzle',61:'Light rain',63:'Rain',65:'Heavy rain',71:'Light snow',73:'Snow',75:'Heavy snow',80:'Showers',81:'Heavy showers',82:'Violent showers',95:'Thunderstorm',96:'Thunderstorm+hail',99:'Thunderstorm+hail'};
const WICO={0:'вҳҖпёҸ',1:'рҹҢӨпёҸ',2:'вӣ…',3:'вҳҒпёҸ',45:'рҹҢ«пёҸ',48:'рҹҢ«пёҸ',51:'рҹҢҰпёҸ',53:'рҹҢҰпёҸ',55:'рҹҢ§пёҸ',61:'рҹҢҰпёҸ',63:'рҹҢ§пёҸ',65:'рҹҢ§пёҸ',71:'рҹҢЁпёҸ',73:'вқ„пёҸ',75:'вқ„пёҸ',80:'рҹҢ§пёҸ',81:'рҹҢ§пёҸ',82:'вӣҲпёҸ',95:'вӣҲпёҸ',96:'вӣҲпёҸ',99:'вӣҲпёҸ'};
const wico=c=>WICO[c]||'рҹҢЎпёҸ',wdesc=c=>WMO[c]||'Unknown';
const OTAGS={restaurants:[['amenity','restaurant'],['amenity','fast_food']],parks:[['leisure','park'],['leisure','garden'],['leisure','nature_reserve']],cafes:[['amenity','cafe']],museums:[['tourism','museum'],['tourism','gallery'],['amenity','arts_centre']],hiking:[['leisure','nature_reserve'],['route','hiking']],bars:[['amenity','bar'],['amenity','pub'],['amenity','nightclub']],shopping:[['shop','mall'],['shop','department_store'],['amenity','marketplace']],beaches:[['natural','beach'],['leisure','beach_resort']]};

/* в”Җв”Җ state в”Җв”Җ */
let userLat,userLon,currentWeather={},nearbyList=[];
let map,placeMarkers=[],cityMarkers=[],searchLat,searchLon;
let activeFilterWords=[],lastPlaces=[],searchRadiusMi=2;
let editingId=null,formTags=[],formStars=3;
let hoverDebounce=null,lastHoveredCity='';

/* в”Җв”Җ tab switching в”Җв”Җ */
function switchTab(name,el){
  document.querySelectorAll('.rtab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('tab-'+name).classList.add('active');
  if(name==='reviews') renderReviews();
}

/* в”Җв”Җ radius в”Җв”Җ */
function onRadiusSlide(val){
  searchRadiusMi=parseFloat(val);
  document.getElementById('radiusVal').textContent=searchRadiusMi+' mi';
  document.querySelectorAll('.rpill').forEach(p=>p.classList.remove('on'));
}
function setRadius(mi,el){
  searchRadiusMi=mi;
  document.getElementById('radiusSlider').value=mi;
  document.getElementById('radiusVal').textContent=mi+' mi';
  document.querySelectorAll('.rpill').forEach(p=>p.classList.remove('on'));
  if(el)el.classList.add('on');
}

/* в”Җв”Җ keyword filter в”Җв”Җ */
function onFilterInput(){
  const words=[...new Set(document.getElementById('filterInput').value.split(/[\s,]+/).map(w=>w.trim().toLowerCase()).filter(w=>w.length>1))];
  activeFilterWords=words;renderFilterTags();applyFilter();
}
function renderFilterTags(){
  const c=document.getElementById('filterTags');c.innerHTML='';
  activeFilterWords.forEach(w=>{const t=document.createElement('span');t.className='ftag';t.innerHTML=`${w}<span class="ftag-x">вң•</span>`;t.onclick=()=>{activeFilterWords=activeFilterWords.filter(x=>x!==w);document.getElementById('filterInput').value=activeFilterWords.join(', ');renderFilterTags();applyFilter();};c.appendChild(t);});
}
function clearFilter(){activeFilterWords=[];document.getElementById('filterInput').value='';document.getElementById('filterTags').innerHTML='';document.getElementById('filterCount').textContent='';applyFilter();}
function highlight(text,words){if(!words.length)return text;const re=new RegExp(`(${words.map(w=>w.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')).join('|')})`,'gi');return text.replace(re,'<mark>$1</mark>');}
function applyFilter(){
  if(!lastPlaces.length)return;
  const words=activeFilterWords;const cards=document.querySelectorAll('.pcard');let mc=0;
  lastPlaces.forEach((p,i)=>{
    const card=cards[i];if(!card)return;
    const t=p.tags||{};
    const s=[t.name,t.amenity,t['addr:street'],t.opening_hours,t.cuisine,t.description].filter(Boolean).join(' ').toLowerCase();
    if(!words.length){card.classList.remove('dimmed','matched');const n=card.querySelector('.pname');if(n&&p._origName)n.innerHTML=p._origName;return;}
    const matched=words.every(w=>s.includes(w));
    card.classList.toggle('dimmed',!matched);card.classList.toggle('matched',matched);if(matched)mc++;
    const n=card.querySelector('.pname');if(n){if(!p._origName)p._origName=n.innerHTML;n.innerHTML=matched?highlight(p._origName,words):p._origName;}
    const mk=placeMarkers[i];if(mk){const e=mk.getElement();if(e)e.style.opacity=matched?'1':'0.2';}
  });
  document.getElementById('filterCount').textContent=words.length?`${mc} of ${lastPlaces.length} match`:'';
  if(!words.length)placeMarkers.forEach(m=>{const e=m.getElement();if(e)e.style.opacity='1';});
}

/* в”Җв”Җ helpers в”Җв”Җ */
function calcScore(tc,wind,vis,hum){const tf=tc*9/5+32;let s=100;if(tf<40||tf>95)s-=30;else if(tf<50||tf>86)s-=15;if(wind>25)s-=22;else if(wind>15)s-=10;if(vis<3)s-=20;else if(vis<5)s-=8;if(hum>85)s-=12;else if(hum>72)s-=5;return Math.max(5,Math.min(100,Math.round(s)));}
const scol=s=>s>=80?'#22c55e':s>=60?'#3b82f6':'#f59e0b';
const bcls=s=>s>=80?'bb':s>=60?'bg':'bf';
const blbl=s=>s>=80?'Best':s>=60?'Good':'Fair';
function distKm(a,b,c,d){const R=6371,dLat=(c-a)*Math.PI/180,dLon=(d-b)*Math.PI/180;const x=Math.sin(dLat/2)**2+Math.cos(a*Math.PI/180)*Math.cos(c*Math.PI/180)*Math.sin(dLon/2)**2;return R*2*Math.atan2(Math.sqrt(x),Math.sqrt(1-x));}
function friendlyType(tags){if(tags.amenity)return tags.amenity.replace(/_/g,' ');if(tags.leisure)return tags.leisure.replace(/_/g,' ');if(tags.tourism)return tags.tourism.replace(/_/g,' ');if(tags.shop)return tags.shop.replace(/_/g,' ')+' shop';if(tags.natural)return tags.natural;return'place';}
function pinColor(tags){const a=tags.amenity||'',l=tags.leisure||'',t=tags.tourism||'',s=tags.shop||'',n=tags.natural||'';if(['restaurant','fast_food','food_court'].includes(a))return'#e11d48';if(['cafe','coffee_shop'].includes(a))return'#d97706';if(['bar','pub','nightclub'].includes(a))return'#7c3aed';if(['park','garden','nature_reserve'].includes(l)||n==='beach')return'#16a34a';if(['museum','gallery','arts_centre'].includes(t)||a==='arts_centre')return'#7c3aed';if(s||a==='marketplace')return'#0891b2';return'#0891b2';}
function setStatus(msg,state){document.getElementById('statusText').textContent=msg;document.getElementById('dot').className='dot'+(state?' '+state:'');}
function starsHtml(n){return'вҳ…'.repeat(n)+'вҳҶ'.repeat(5-n);}

/* в”Җв”Җ map init в”Җв”Җ */
function initMap(lat,lon){
  if(map){map.remove();map=null;}
  clearCityMarkers();
  map=new maplibregl.Map({container:'map',style:'https://tiles.openfreemap.org/styles/liberty',center:[lon,lat],zoom:13,attributionControl:true});
  map.addControl(new maplibregl.NavigationControl({showCompass:false}),'top-right');
  map.addControl(new maplibregl.GeolocateControl({positionOptions:{enableHighAccuracy:true},trackUserLocation:false}),'top-right');
  const el=document.createElement('div');
  el.style.cssText='width:18px;height:18px;border-radius:50%;background:#1d4ed8;border:3px solid #fff;box-shadow:0 0 0 2px #1d4ed8,0 2px 6px rgba(0,0,0,.3);cursor:pointer';
  new maplibregl.Marker({element:el,anchor:'center'}).setLngLat([lon,lat]).setPopup(new maplibregl.Popup({offset:12}).setHTML('<b>рҹ“Қ You are here</b>')).addTo(map);
}

/* в”Җв”Җ city markers with hover-to-activity в”Җв”Җ */
function clearCityMarkers(){cityMarkers.forEach(m=>{try{m.remove();}catch{}});cityMarkers=[];}

function addCityMarkers(areas){
  clearCityMarkers();
  if(!map)return;
  areas.forEach((a,idx)=>{
    const col=a.sc>=80?'#16a34a':a.sc>=60?'#2563eb':'#d97706';
    const icon=[0,1].includes(a.code)?'вҳҖ':[2,3].includes(a.code)?'вӣ…':[45,48].includes(a.code)?'рҹҢ«':[51,53,55,61,63,65,80,81,82].includes(a.code)?'рҹҢ§':[71,73,75].includes(a.code)?'вқ„':[95,96,99].includes(a.code)?'вӣҲ':'рҹҢЎ';
    const el=document.createElement('div');
    el.style.cssText='display:flex;flex-direction:column;align-items:center;cursor:pointer;filter:drop-shadow(0 2px 4px rgba(0,0,0,.22));';
    el.innerHTML=`<div style="background:#fff;border:2px solid ${col};border-radius:8px;padding:3px 7px;display:flex;align-items:center;gap:4px;font-family:-apple-system,sans-serif;white-space:nowrap"><span style="font-size:11px">${icon}</span><span style="font-size:11px;font-weight:700;color:${col}">${a.temp}В°F</span><span style="font-size:10px;font-weight:600;color:#1a1a2e;max-width:80px;overflow:hidden;text-overflow:ellipsis">${a.name.split(',')[0]}</span></div><div style="width:2px;height:6px;background:${col};margin:0 auto"></div><div style="width:8px;height:8px;border-radius:50%;background:${col};border:2px solid #fff"></div>`;
    const marker=new maplibregl.Marker({element:el,anchor:'bottom'}).setLngLat([a.lon,a.lat]).addTo(map);

    // hover вҶ’ show activities in left panel
    el.addEventListener('mouseenter',()=>onCityHover(a,idx));
    el.addEventListener('mouseleave',()=>onCityLeave(idx));
    // click вҶ’ search places in that city
    el.addEventListener('click',()=>{
      searchLat=a.lat;searchLon=a.lon;
      map.flyTo({center:[a.lon,a.lat],zoom:13,duration:700});
      const q=document.getElementById('searchInput').value.trim()||'things to do';
      document.querySelectorAll('.rtab')[0].click();
      performSearch(q,a.lat,a.lon,a.name);
    });
    cityMarkers.push(marker);
  });
}

function onCityHover(area,idx){
  clearTimeout(hoverDebounce);
  if(lastHoveredCity===area.key) return;
  lastHoveredCity=area.key;
  // highlight sidebar card
  document.querySelectorAll('.area-item').forEach((el,i)=>{el.classList.toggle('hovered',i===idx);});
  // show hover panel
  const panel=document.getElementById('hoverPanel');
  const nameEl=document.getElementById('hoverCityName');
  const actEl=document.getElementById('hoverActivities');
  nameEl.textContent=`${area.name} вҖ” ${area.temp}В°F ${wdesc(area.code)}`;
  actEl.innerHTML='<span class="spin"></span> Loading activity ideasвҖҰ';
  panel.classList.add('visible');
  hoverDebounce=setTimeout(()=>fetchCityActivities(area,actEl),400);
}

function onCityLeave(idx){
  clearTimeout(hoverDebounce);
  document.querySelectorAll('.area-item').forEach(el=>el.classList.remove('hovered'));
}

async function fetchCityActivities(area,actEl){
  const wx=currentWeather;
  const prompt=`City: ${area.name}. Weather: ${area.temp}В°F, ${wdesc(area.code)}, wind ${area.wind}mph, humidity ${area.hum}%.
Current user location weather: ${wx.temp||'?'}В°F, ${wdesc(wx.code)}.
List 4-5 specific activities or places to visit in ${area.name.split(',')[0]} that suit today's weather. Format as a short bulleted list using вҖў symbol. Each item max 10 words. No markdown.`;
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:400,system:'You are a local activity guide. Short, practical bullet list only. Use вҖў for bullets. No markdown headers.',messages:[{role:'user',content:prompt}]})});
    const data=await res.json();
    const text=data.content?.filter(b=>b.type==='text').map(b=>b.text).join('')||'';
    // format bullets
    const lines=text.split('\n').map(l=>l.trim()).filter(l=>l.startsWith('вҖў')||l.startsWith('-'));
    if(lines.length){
      actEl.innerHTML=lines.map(l=>`<div style="margin-bottom:3px">${l.replace(/^[-вҖў]\s*/,'<b>вҖў</b> ')}</div>`).join('');
    }else{
      actEl.innerHTML=text.replace(/\n/g,'<br>');
    }
  }catch{
    actEl.innerHTML='<b>вҖў</b> Check local parks and cafes<br><b>вҖў</b> Visit the downtown area<br><b>вҖў</b> Explore local museums';
  }
}

/* в”Җв”Җ weather в”Җв”Җ */
async function fetchWx(lat,lon){const r=await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat.toFixed(4)}&longitude=${lon.toFixed(4)}&current=temperature_2m,relative_humidity_2m,apparent_temperature,weather_code,wind_speed_10m,visibility,uv_index&temperature_unit=fahrenheit&wind_speed_unit=mph&timezone=auto`);if(!r.ok)throw new Error('wx');return r.json();}

async function geocode(lat,lon){
  try{
    const r=await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat.toFixed(5)}&lon=${lon.toFixed(5)}&format=json&zoom=10&addressdetails=1`,{headers:{'Accept-Language':'en'}});
    const d=await r.json();const a=d.address||{};
    const city=a.city||a.town||a.village||a.municipality||a.suburb||a.neighbourhood||a.hamlet||'';
    if(!city)return{label:'Unknown',key:'unknown'};
    const state=a.state_code||'';
    return{label:state?`${city}, ${state}`:city,key:city.toLowerCase().trim()};
  }catch{return{label:'Unknown',key:'unknown'};}
}

function renderWeather(wx,name){
  const c=wx.current;
  const temp=Math.round(c.temperature_2m),feel=Math.round(c.apparent_temperature);
  const hum=Math.round(c.relative_humidity_2m),wind=Math.round(c.wind_speed_10m);
  const vis=c.visibility!=null?Math.round(c.visibility/160.934)/10:null;
  const uv=c.uv_index!=null?Math.round(c.uv_index):null;
  const code=c.weather_code;
  currentWeather={temp,feel,hum,wind,vis,uv,code,name};
  document.getElementById('weatherPanel').innerHTML=`<div class="loc-name">${name}</div><div class="hero"><div class="hero-icon">${wico(code)}</div><div><div class="hero-temp">${temp}В°F</div><div class="hero-sub">Feels ${feel}В°F В· ${wdesc(code)}</div></div></div><div class="g2"><div class="tile"><div class="tl">Humidity</div><div class="tv">${hum}%</div></div><div class="tile"><div class="tl">Wind</div><div class="tv">${wind} mph</div></div>${vis!=null?`<div class="tile"><div class="tl">Visibility</div><div class="tv">${vis} mi</div></div>`:''}${uv!=null?`<div class="tile"><div class="tl">UV index</div><div class="tv">${uv}</div></div>`:''}</div>`;
}

const DIRS=[{dlat:.28,dlon:0},{dlat:.2,dlon:.2},{dlat:0,dlon:.28},{dlat:-.2,dlon:.2},{dlat:-.28,dlon:0},{dlat:-.2,dlon:-.2},{dlat:0,dlon:-.28},{dlat:.2,dlon:-.2}];

async function loadNearby(){
  document.getElementById('nearbyPanel').innerHTML='<span class="ghost" style="font-size:12px">Fetching nearby citiesвҖҰ</span>';
  const raw=await Promise.all(DIRS.map(async o=>{
    const lat=userLat+o.dlat,lon=userLon+o.dlon;
    const [wx,geo]=await Promise.all([fetchWx(lat,lon),geocode(lat,lon)]);
    const c=wx.current;
    const tc=(c.temperature_2m-32)*5/9,wind=Math.round(c.wind_speed_10m);
    const vis=c.visibility!=null?c.visibility/1609.34:10,hum=Math.round(c.relative_humidity_2m);
    const temp=Math.round(c.temperature_2m),dist=Math.round(Math.sqrt(o.dlat**2+o.dlon**2)*69);
    return{name:geo.label,key:geo.key,lat,lon,temp,wind,hum,code:c.weather_code,dist,sc:calcScore(tc,wind,vis,hum)};
  }));
  const seen=new Map();
  raw.forEach(a=>{if(a.key==='unknown')return;const ex=seen.get(a.key);if(!ex||a.sc>ex.sc)seen.set(a.key,a);});
  const userKey=(currentWeather.name||'').toLowerCase().split(',')[0].trim();
  seen.delete(userKey);
  nearbyList=[...seen.values()].sort((a,b)=>b.sc-a.sc).slice(0,6);

  const panel=document.getElementById('nearbyPanel');panel.innerHTML='';
  nearbyList.forEach((a,i)=>{
    const d=document.createElement('div');
    d.className='area-item'+(i===0?' top':'');
    d.dataset.cityIdx=i;
    d.onmouseenter=()=>onCityHover(a,i);
    d.onmouseleave=()=>onCityLeave(i);
    d.onclick=()=>{
      searchLat=a.lat;searchLon=a.lon;
      map.flyTo({center:[a.lon,a.lat],zoom:13,duration:800});
      const q=document.getElementById('searchInput').value.trim()||'things to do';
      document.querySelectorAll('.rtab')[0].click();
      performSearch(q,a.lat,a.lon,a.name);
    };
    d.innerHTML=`<div class="arow"><span class="aname">${a.name}</span><span class="badge ${bcls(a.sc)}">${blbl(a.sc)}</span></div><div class="asub">${wico(a.code)} ${a.temp}В°F В· ${wdesc(a.code)} В· ~${a.dist} mi</div><div class="bar"><div class="bfill" style="width:${a.sc}%;background:${scol(a.sc)}"></div></div><div class="tap-hint">Hover for activities В· click to search вҶ’</div>`;
    panel.appendChild(d);
  });

  if(map){
    const go=()=>{
      addCityMarkers(nearbyList);
      const pts=[[userLon,userLat],...nearbyList.map(a=>[a.lon,a.lat])];
      const lons=pts.map(p=>p[0]),lats=pts.map(p=>p[1]);
      map.fitBounds([[Math.min(...lons),Math.min(...lats)],[Math.max(...lons),Math.max(...lats)]],{padding:60,maxZoom:11,duration:800});
    };
    map.isStyleLoaded()?go():map.once('styledata',go);
  }
}

async function startTracking(){
  setStatus('Fetching live weatherвҖҰ','busy');
  ['aiBtn','refreshBtn','searchBtn'].forEach(id=>document.getElementById(id).disabled=true);
  try{
    const [wx,geo]=await Promise.all([fetchWx(userLat,userLon),geocode(userLat,userLon)]);
    const locName=geo.label!=='Unknown'?geo.label:'Your location';
    renderWeather(wx,locName);
    initMap(userLat,userLon);
    searchLat=userLat;searchLon=userLon;
    document.getElementById('coordsText').textContent=Math.abs(userLat).toFixed(4)+'В°'+(userLat>=0?'N':'S')+' '+Math.abs(userLon).toFixed(4)+'В°'+(userLon>=0?'E':'W');
    setStatus('Live вҖ” '+locName,'');
    ['aiBtn','refreshBtn','searchBtn'].forEach(id=>document.getElementById(id).disabled=false);
    await loadNearby();
  }catch(e){
    setStatus('Weather fetch failed','err');
    document.getElementById('weatherPanel').innerHTML='<span style="font-size:12px;color:#ef4444">Could not load weather. Check connection then Refresh.</span>';
  }
}

/* в”Җв”Җ place search в”Җв”Җ */
function buildQuery(lat,lon,tags,r=3200){const cap=r>8000?40:25;return`[out:json][timeout:15];(${tags.map(([k,v])=>`node["${k}"="${v}"](around:${r},${lat},${lon});way["${k}"="${v}"](around:${r},${lat},${lon});`).join('')});out center ${cap};`;}

async function fetchPlaces(query,lat,lon){
  const radiusMi=searchRadiusMi;
  const cityName=currentWeather.name||`${lat.toFixed(3)},${lon.toFixed(3)}`;
  const userPrompt=`Find up to 12 real places matching "${query}" within ${radiusMi} miles of ${cityName} (coordinates: ${lat.toFixed(4)}, ${lon.toFixed(4)}).\nSearch the web to find real, currently operating places with exact coordinates.\nReply ONLY with a JSON array (no markdown):\n[{"name":"Place","type":"cafe","lat":37.123,"lon":-121.456,"address":"123 Main St","hours":"9am-5pm","phone":"","website":"https://..."},...]\nCoordinates must be real and accurate.`;
  const messages=[{role:'user',content:userPrompt}];
  try{
    for(let i=0;i<5;i++){
      const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:4000,tools:[{type:'web_search_20250305',name:'web_search'}],system:'You are a local place-finder. Use web_search to find real businesses. Respond ONLY with a valid JSON array of places with accurate lat/lon. No markdown, no prose.',messages})});
      const data=await res.json();
      if(!data.content||data.error)break;
      const textBlocks=data.content.filter(b=>b.type==='text');
      const toolBlocks=data.content.filter(b=>b.type==='tool_use');
      if(data.stop_reason==='end_turn'){const places=extractPlacesJSON(textBlocks.map(b=>b.text).join(''));if(places.length)return normalisePlaces(places);break;}
      if(data.stop_reason==='tool_use'&&toolBlocks.length){messages.push({role:'assistant',content:data.content});messages.push({role:'user',content:toolBlocks.map(tb=>({type:'tool_result',tool_use_id:tb.id,content:''}))});continue;}
      const places=extractPlacesJSON(textBlocks.map(b=>b.text).join(''));if(places.length)return normalisePlaces(places);break;
    }
  }catch(e){console.error(e);}
  return[];
}

function extractPlacesJSON(text){
  if(!text)return[];
  try{const a=JSON.parse(text.replace(/```json|```/g,'').trim());if(Array.isArray(a))return a;}catch{}
  const m=text.match(/\[[\s\S]*\]/);if(m){try{const a=JSON.parse(m[0]);if(Array.isArray(a))return a;}catch{}}
  return[];
}
function normalisePlaces(arr){
  return arr.map(p=>({tags:{name:String(p.name||'').trim(),amenity:String(p.type||p.category||'place').toLowerCase(),'addr:street':String(p.address||p.addr||'').trim(),opening_hours:String(p.hours||p.opening_hours||'').trim(),phone:String(p.phone||'').trim(),website:String(p.website||p.url||'').trim()},_lat:parseFloat(p.lat||p.latitude||0),_lon:parseFloat(p.lon||p.lng||p.longitude||0)})).filter(p=>p.tags.name&&p._lat!==0&&p._lon!==0&&!isNaN(p._lat)&&!isNaN(p._lon));
}
function clearPlaceMarkers(){
  placeMarkers.forEach(m=>{try{m.remove();}catch{}});placeMarkers=[];
  if(map){['radius-fill','radius-line'].forEach(l=>{if(map.getLayer(l))map.removeLayer(l);});if(map.getSource('radius-circle'))map.removeSource('radius-circle');}
}
function drawRadiusCircle(lat,lon,mi){
  if(!map)return;const rk=mi*1.60934,steps=64,coords=[];
  for(let i=0;i<=steps;i++){const a=(i/steps)*2*Math.PI;coords.push([lon+(rk/(111.32*Math.cos(lat*Math.PI/180)))*Math.cos(a),lat+(rk/111.32)*Math.sin(a)]);}
  const go=()=>{if(map.getSource('radius-circle'))return;map.addSource('radius-circle',{type:'geojson',data:{type:'Feature',geometry:{type:'Polygon',coordinates:[coords]}}});map.addLayer({id:'radius-fill',type:'fill',source:'radius-circle',paint:{'fill-color':'#1d4ed8','fill-opacity':0.05}});map.addLayer({id:'radius-line',type:'line',source:'radius-circle',paint:{'line-color':'#1d4ed8','line-width':1.5,'line-dasharray':[3,3],'line-opacity':0.5}});};
  map.isStyleLoaded()?go():map.once('load',go);
}
function chipClick(el,cat){document.querySelectorAll('.chip').forEach(c=>c.classList.remove('on'));el.classList.add('on');document.getElementById('searchInput').value=cat;doSearch();}
async function doSearch(){const q=document.getElementById('searchInput').value.trim();if(!q)return;await performSearch(q,searchLat||userLat,searchLon||userLon,currentWeather.name||'your area');}

async function performSearch(query,lat,lon,locName){
  const resultsEl=document.getElementById('searchResults'),aiEl=document.getElementById('searchAiBox');
  const steps=[`<span class="spin"></span>Searching for <b>${query}</b> near ${locName}вҖҰ`,`<span class="spin"></span>Finding locations within ${searchRadiusMi} miвҖҰ`,`<span class="spin"></span>Mapping resultsвҖҰ`];
  let si=0;resultsEl.innerHTML=`<div class="nores">${steps[0]}</div>`;aiEl.innerHTML=`<span class="spin"></span>WaitingвҖҰ`;
  const timer=setInterval(()=>{si=(si+1)%steps.length;const e=resultsEl.querySelector('.nores');if(e)e.innerHTML=steps[si];},3000);
  clearPlaceMarkers();drawRadiusCircle(lat,lon,searchRadiusMi);
  let places=await fetchPlaces(query,lat,lon);clearInterval(timer);
  places=places.filter(p=>p.tags?.name).map(p=>({...p,_dist:distKm(lat,lon,p._lat,p._lon)})).filter(p=>p._dist<=searchRadiusMi*1.61).sort((a,b)=>a._dist-b._dist).slice(0,searchRadiusMi<=2?14:searchRadiusMi<=10?20:30);
  if(!places.length){resultsEl.innerHTML=`<div class="nores">No "${query}" found within ${searchRadiusMi} mi.<br>Try increasing the radius.</div>`;aiEl.innerHTML=`<span class="ghost">No places found.</span>`;document.getElementById('filterBar').style.display='none';return;}
  lastPlaces=places;activeFilterWords=[];
  document.getElementById('filterInput').value='';document.getElementById('filterTags').innerHTML='';document.getElementById('filterCount').textContent='';document.getElementById('filterBar').style.display='block';
  const bounds=[[userLon,userLat]];resultsEl.innerHTML='';
  places.forEach((p,i)=>{
    const t=p.tags||{},name=t.name||'Unnamed',type=friendlyType(t),color=pinColor(t),num=i+1;
    const dist=p._dist<1?(p._dist*1000).toFixed(0)+' m':(p._dist).toFixed(2)+' km';
    const addr=t['addr:street']||'',hours=t.opening_hours||'',phone=t.phone||'',web=t.website||'';
    const el=document.createElement('div');el.style.cssText='width:28px;height:38px;cursor:pointer';
    el.innerHTML=`<svg width="28" height="38" viewBox="0 0 28 38" xmlns="http://www.w3.org/2000/svg" style="filter:drop-shadow(0 2px 4px rgba(0,0,0,.28))"><path d="M14 0C6.27 0 0 6.27 0 14c0 9.6 14 24 14 24S28 23.6 28 14C28 6.27 21.73 0 14 0z" fill="${color}"/><circle cx="14" cy="14" r="8.5" fill="white"/><text x="14" y="18.5" text-anchor="middle" font-size="${num>9?8:10}" font-weight="700" fill="${color}" font-family="-apple-system,sans-serif">${num}</text></svg>`;
    const popup=new maplibregl.Popup({offset:[0,-38],closeButton:true}).setHTML(`<b>${name}</b><span class="ptyplabel">${type}</span>${addr?`<div class="pmeta-popup">рҹ“Қ ${addr}</div>`:''}${hours?`<div class="pmeta-popup">рҹ•җ ${hours}</div>`:''}${phone?`<div class="pmeta-popup">рҹ“һ ${phone}</div>`:''}${web?`<div class="pmeta-popup"><a href="${web}" target="_blank" style="color:#1d4ed8">Website вҶ—</a></div>`:''}`);
    const marker=new maplibregl.Marker({element:el,anchor:'bottom'}).setLngLat([p._lon,p._lat]).setPopup(popup).addTo(map);
    placeMarkers.push(marker);bounds.push([p._lon,p._lat]);
    const card=document.createElement('div');card.className='pcard';
    card.onclick=()=>{map.flyTo({center:[p._lon,p._lat],zoom:16,duration:600});marker.togglePopup();document.querySelectorAll('.pcard').forEach(c=>c.classList.remove('hi'));card.classList.add('hi');};
    card.innerHTML=`<div class="ptop"><div class="pname"><span class="pdot" style="background:${color}"></span>${num}. ${name}</div><div class="ptyp">${type}</div></div><div class="pdist">${dist} away</div>${addr?`<div class="pmeta">рҹ“Қ ${addr}</div>`:''}${hours?`<div class="pmeta">рҹ•җ ${hours}</div>`:''}${phone?`<div class="pmeta">рҹ“һ ${phone}</div>`:''}${web?`<div class="pmeta"><a href="${web}" target="_blank" style="color:#1d4ed8;font-size:11px">Website вҶ—</a></div>`:''}`;
    resultsEl.appendChild(card);
  });
  if(bounds.length>1){const lons=bounds.map(b=>b[0]),lats=bounds.map(b=>b[1]);map.fitBounds([[Math.min(...lons),Math.min(...lats)],[Math.max(...lons),Math.max(...lats)]],{padding:50,maxZoom:15,duration:700});}
  getActivityAI(places,query,locName);
}

async function getActivityAI(places,query,locName){
  const aiEl=document.getElementById('searchAiBox');
  const top=places.slice(0,6).map((p,i)=>`${i+1}. ${p.tags?.name||'Place'} (${friendlyType(p.tags||{})}, ${p._dist<1?(p._dist*1000).toFixed(0)+'m':(p._dist).toFixed(1)+'km'} away)`).join('\n');
  const wx=currentWeather;
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:'Helpful local activity advisor. Plain text only, no markdown.',messages:[{role:'user',content:`Location: ${locName}. Weather: ${wx.temp}В°F, ${wdesc(wx.code)}, wind ${wx.wind}mph.\nTop "${query}":\n${top}\n2-3 sentences: best pinned place for today's weather and why, one visiting tip.`}]})});
    const data=await res.json();const text=data.content?.filter(b=>b.type==='text').map(b=>b.text).join('')||'';
    const names=places.slice(0,6).map(p=>p.tags?.name).filter(Boolean);
    aiEl.innerHTML=names.length?text.replace(new RegExp(names.map(n=>n.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')).join('|'),'g'),m=>`<b>${m}</b>`):text;
  }catch{aiEl.innerHTML=`<b>#1 ${places[0]?.tags?.name||'closest spot'}</b> is your nearest option. Tap any pin for details.`;}
}

async function runAI(){
  const btn=document.getElementById('aiBtn'),box=document.getElementById('aiBox');
  btn.disabled=true;box.innerHTML=`<span class="spin"></span>AnalysingвҖҰ`;
  const wx=currentWeather,nearby=nearbyList.map(a=>`- ${a.name}: ${a.temp}В°F, ${wdesc(a.code)}, score ${a.sc}/100, ~${a.dist}mi`).join('\n');
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:'Concise GPS weather travel advisor. Plain text only.',messages:[{role:'user',content:`My location: ${wx.name} вҖ” ${wx.temp}В°F, ${wdesc(wx.code)}, wind ${wx.wind}mph, humidity ${wx.hum}%.\nNearby cities:\n${nearby}\n3 sentences: best city to travel to and why, travel cautions, one activity for today.`}]})});
    const data=await res.json();const text=data.content?.filter(b=>b.type==='text').map(b=>b.text).join('')||'';
    const names=nearbyList.map(a=>a.name.split(',')[0]).filter(Boolean);
    box.innerHTML=names.length?text.replace(new RegExp(names.join('|'),'g'),m=>`<b>${m}</b>`):text;
  }catch{box.innerHTML=`<b>${nearbyList[0]?.name||'nearest city'}</b> has the best conditions right now.`;}
  btn.disabled=false;
}

/* в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
   LOCATION REVIEWER вҖ” localStorage
в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ */
function loadReviews(){try{return JSON.parse(localStorage.getItem('gps_reviews')||'[]');}catch{return[];}}
function saveReviews(arr){try{localStorage.setItem('gps_reviews',JSON.stringify(arr));}catch{}}

function renderReviews(){
  const list=document.getElementById('reviewsList');
  const reviews=loadReviews();
  if(!reviews.length){list.innerHTML='<div class="no-reviews">No reviews yet.<br>Search for places then add your first review!</div>';return;}
  list.innerHTML='';
  reviews.slice().reverse().forEach(r=>{
    const card=document.createElement('div');card.className='rev-card';
    card.innerHTML=`<div class="rev-card-top"><div class="rev-place-name">${r.name}</div><div class="rev-stars">${starsHtml(r.stars||3)}</div></div><div class="rev-meta">${r.type||'place'} ${r.address?'В· '+r.address:''} В· ${new Date(r.ts).toLocaleDateString()}</div><div class="rev-text">${r.review||'<em style="color:#9ca3af">No review text</em>'}</div>${r.tags?.length?`<div class="rev-tags">${r.tags.map(t=>`<span class="rev-tag">${t}</span>`).join('')}</div>`:''}${r.website?`<div style="margin-top:5px"><a href="${r.website}" target="_blank" style="font-size:11px;color:#1d4ed8">Website вҶ—</a></div>`:''}<div class="rev-actions"><button class="rev-act-btn" onclick="editReview('${r.id}')">вңҸ Edit</button><button class="rev-act-btn del" onclick="deleteReview('${r.id}')">вң• Delete</button></div>`;
    list.appendChild(card);
  });
}

function openModal(prefill){
  editingId=null;formTags=[];formStars=3;
  document.getElementById('fName').value=prefill?.name||'';
  document.getElementById('fType').value=prefill?.type||'';
  document.getElementById('fAddr').value=prefill?.address||'';
  document.getElementById('fReview').value='';
  document.getElementById('fWeb').value='';
  document.getElementById('fTags').innerHTML='';
  document.getElementById('fTagInput').value='';
  document.getElementById('modalTitle').textContent='Add location review';
  setStar(3);
  document.getElementById('modalOverlay').classList.add('open');
}

function editReview(id){
  const reviews=loadReviews();const r=reviews.find(x=>x.id===id);if(!r)return;
  editingId=id;formTags=r.tags||[];formStars=r.stars||3;
  document.getElementById('fName').value=r.name||'';
  document.getElementById('fType').value=r.type||'';
  document.getElementById('fAddr').value=r.address||'';
  document.getElementById('fReview').value=r.review||'';
  document.getElementById('fWeb').value=r.website||'';
  document.getElementById('fTags').innerHTML='';
  formTags.forEach(t=>renderTagChip(t));
  document.getElementById('fTagInput').value='';
  document.getElementById('modalTitle').textContent='Edit location review';
  setStar(formStars);
  document.getElementById('modalOverlay').classList.add('open');
}

function deleteReview(id){
  if(!confirm('Delete this review?'))return;
  const reviews=loadReviews().filter(r=>r.id!==id);saveReviews(reviews);renderReviews();
}

function closeModal(){document.getElementById('modalOverlay').classList.remove('open');}

function setStar(n){
  formStars=n;
  document.querySelectorAll('.star-btn').forEach(b=>{b.classList.toggle('lit',parseInt(b.dataset.v)<=n);});
}

function addTag(){
  const input=document.getElementById('fTagInput');
  const val=input.value.trim().toLowerCase();
  if(!val||formTags.includes(val))return;
  formTags.push(val);renderTagChip(val);input.value='';
}

function renderTagChip(tag){
  const chip=document.createElement('span');chip.className='tag-chip';chip.textContent=tag;
  chip.onclick=()=>{formTags=formTags.filter(t=>t!==tag);chip.remove();};
  document.getElementById('fTags').appendChild(chip);
}

function saveReview(){
  const name=document.getElementById('fName').value.trim();
  if(!name){alert('Place name is required.');return;}
  const reviews=loadReviews();
  const entry={id:editingId||('r'+Date.now()),name,type:document.getElementById('fType').value.trim(),address:document.getElementById('fAddr').value.trim(),review:document.getElementById('fReview').value.trim(),website:document.getElementById('fWeb').value.trim(),stars:formStars,tags:[...formTags],ts:editingId?reviews.find(r=>r.id===editingId)?.ts||Date.now():Date.now()};
  if(editingId){const idx=reviews.findIndex(r=>r.id===editingId);if(idx>=0)reviews[idx]=entry;else reviews.push(entry);}else{reviews.push(entry);}
  saveReviews(reviews);closeModal();renderReviews();
  // switch to reviews tab
  document.querySelectorAll('.rtab')[1].click();
}

/* в”Җв”Җ boot в”Җв”Җ */
if(navigator.geolocation){
  navigator.geolocation.getCurrentPosition(
    p=>{userLat=p.coords.latitude;userLon=p.coords.longitude;startTracking();},
    ()=>{setStatus('Location denied вҖ” defaulting to San Jose, CA','');userLat=37.3382;userLon=-121.8863;startTracking();},
    {enableHighAccuracy:true,timeout:10000}
  );
}else{
  setStatus('Geolocation unavailable вҖ” defaulting to San Jose, CA','err');
  userLat=37.3382;userLon=-121.8863;startTracking();
}
