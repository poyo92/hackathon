<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Live GPS Weather Tracker</title>
<link href="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f0f2f5;color:#1a1a2e}
.app{display:flex;flex-direction:column;max-width:1160px;margin:0 auto;height:100vh;min-height:600px;border-left:1px solid #dde1e7;border-right:1px solid #dde1e7;background:#fff;box-shadow:0 2px 16px rgba(0,0,0,.08)}
.topbar{display:flex;align-items:center;gap:10px;padding:10px 16px;background:#fff;border-bottom:1px solid #eaecf0;flex-shrink:0;z-index:20}
.dot{width:8px;height:8px;border-radius:50%;background:#22c55e;flex-shrink:0}
.dot.busy{background:#f59e0b;animation:blink 1s infinite}
.dot.err{background:#ef4444}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
#statusText{font-size:13px;font-weight:500}
#coordsText{margin-left:auto;font-size:11px;color:#6b7280;font-family:'Courier New',monospace}
.body{display:grid;grid-template-columns:260px 1fr 300px;flex:1;min-height:0;overflow:hidden}

/* LEFT */
.side{border-right:1px solid #eaecf0;display:flex;flex-direction:column;overflow-y:auto}
.sec{padding:12px 13px;border-bottom:1px solid #eaecf0;flex-shrink:0}
.stitle{font-size:9px;letter-spacing:.13em;text-transform:uppercase;color:#9ca3af;font-weight:600;margin-bottom:8px}
.hero{display:flex;align-items:center;gap:9px;margin-bottom:9px}
.hero-icon{font-size:30px;line-height:1}
.hero-temp{font-size:28px;font-weight:300;font-family:'Courier New',monospace}
.hero-sub{font-size:11px;color:#6b7280;margin-top:1px}
.loc-name{font-size:12px;font-weight:600;color:#374151;margin-bottom:6px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.tile{background:#f8fafc;border-radius:7px;padding:7px 9px;border:1px solid #eaecf0}
.tl{font-size:9px;text-transform:uppercase;letter-spacing:.07em;color:#9ca3af}
.tv{font-size:12px;font-weight:500;font-family:'Courier New',monospace;margin-top:1px;color:#1a1a2e}
.area-item{border:1px solid #eaecf0;border-radius:8px;padding:8px 10px;margin-bottom:6px;cursor:pointer;transition:all .15s}
.area-item:hover{border-color:#9ca3af;background:#fafbfc}
.area-item.top{border-color:#22c55e}
.area-item.hovered{border-color:#1d4ed8;background:#eff6ff}
.arow{display:flex;align-items:center;justify-content:space-between;margin-bottom:2px}
.aname{font-size:12px;font-weight:600}
.badge{font-size:9px;padding:2px 6px;border-radius:9px;font-weight:600}
.bb{background:#dcfce7;color:#15803d}.bg{background:#dbeafe;color:#1d4ed8}.bf{background:#fef9c3;color:#854d0e}
.asub{font-size:11px;color:#6b7280}
.bar{height:3px;background:#e5e7eb;border-radius:2px;margin-top:5px;overflow:hidden}
.bfill{height:100%;border-radius:2px;transition:width .5s}
.tap-hint{font-size:10px;color:#9ca3af;margin-top:3px}

/* hover activity panel */
.hover-panel{background:#f0f6ff;border-top:2px solid #1d4ed8;padding:10px 13px;flex-shrink:0;display:none}
.hover-panel.visible{display:block}
.hover-city-name{font-size:12px;font-weight:700;color:#1d4ed8;margin-bottom:5px}
.hover-activities{font-size:11px;color:#374151;line-height:1.65}
.hover-activities b{font-weight:600;color:#1a1a2e}

/* CENTER */
.maincol{display:flex;flex-direction:column;min-height:0;border-right:1px solid #eaecf0}
#map{flex:1;min-height:0}
.attr-bar{display:flex;align-items:center;justify-content:space-between;padding:5px 10px;background:#fff;border-top:1px solid #eaecf0;flex-shrink:0;flex-wrap:wrap;gap:6px}
.attr-text{font-size:10px;color:#6b7280}.attr-text a{color:#1d4ed8;text-decoration:none}
.legend{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.li{display:flex;align-items:center;gap:4px;font-size:10px;color:#6b7280}
.ld{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.btmpanel{padding:11px 14px;border-top:1px solid #eaecf0;flex-shrink:0;background:#fff}
.brow{display:flex;gap:7px;margin-bottom:7px}
button{font-family:inherit;font-size:12px;font-weight:500;padding:7px 11px;border-radius:8px;border:1px solid #d1d5db;background:#fff;color:#374151;cursor:pointer;transition:all .15s;white-space:nowrap}
button:hover:not(:disabled){background:#f9fafb;border-color:#9ca3af}
button:disabled{opacity:.38;cursor:not-allowed}
.aibox{font-size:12px;color:#374151;line-height:1.7;padding:9px 11px;background:#f8fafc;border-radius:8px;border:1px solid #eaecf0;min-height:42px}
.aibox b{color:#1a1a2e;font-weight:600}
.ghost{color:#9ca3af;font-style:italic}

/* RIGHT вҖ” tabs */
.rpanel{display:flex;flex-direction:column;overflow:hidden}
.rtabs{display:flex;border-bottom:1px solid #eaecf0;flex-shrink:0;background:#fafbfc}
.rtab{flex:1;padding:9px 6px;font-size:11px;font-weight:600;color:#6b7280;cursor:pointer;text-align:center;border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap}
.rtab:hover{color:#374151;background:#f3f4f6}
.rtab.active{color:#1a1a2e;border-bottom-color:#1a1a2e;background:#fff}
.tab-pane{display:none;flex-direction:column;flex:1;overflow:hidden}
.tab-pane.active{display:flex}

/* SEARCH tab */
.rheader{padding:11px 13px;border-bottom:1px solid #eaecf0;flex-shrink:0}
.srow{display:flex;gap:6px;margin-bottom:7px}
.sinput{flex:1;font-family:inherit;font-size:12px;padding:7px 10px;border-radius:8px;border:1px solid #d1d5db;background:#fff;color:#1a1a2e;outline:none;min-width:0}
.sinput:focus{border-color:#6b7280}
.sbtn{font-family:inherit;font-size:12px;font-weight:600;padding:7px 11px;border-radius:8px;border:none;background:#1a1a2e;color:#fff;cursor:pointer;transition:opacity .15s;white-space:nowrap}
.sbtn:hover{opacity:.82}.sbtn:disabled{opacity:.35;cursor:not-allowed}
.chips{display:flex;flex-wrap:wrap;gap:4px}
.chip{font-size:10px;padding:3px 8px;border-radius:10px;border:1px solid #e5e7eb;background:#f9fafb;color:#374151;cursor:pointer;transition:all .15s;white-space:nowrap;user-select:none}
.chip:hover,.chip.on{background:#1a1a2e;color:#fff;border-color:#1a1a2e}
.radius-bar{padding:7px 13px;border-bottom:1px solid #eaecf0;background:#fff;flex-shrink:0}
.radius-row{display:flex;align-items:center;gap:8px}
.radius-label{font-size:11px;color:#6b7280;white-space:nowrap;flex-shrink:0}
.radius-val{font-size:12px;font-weight:600;color:#1a1a2e;min-width:48px;text-align:right;flex-shrink:0;font-family:'Courier New',monospace}
.radius-slider{flex:1;accent-color:#1a1a2e}
.radius-presets{display:flex;gap:4px;margin-top:5px;flex-wrap:wrap}
.rpill{font-size:10px;padding:2px 8px;border-radius:10px;border:1px solid #e5e7eb;background:#f9fafb;color:#374151;cursor:pointer;transition:all .15s}
.rpill:hover,.rpill.on{background:#1a1a2e;color:#fff;border-color:#1a1a2e}
.filter-bar{padding:7px 13px;border-bottom:1px solid #eaecf0;background:#fafbfc;flex-shrink:0;display:none}
.filter-row{display:flex;align-items:center;gap:6px}
.filter-icon{font-size:11px;color:#6b7280;white-space:nowrap;flex-shrink:0}
.filter-input{flex:1;font-family:inherit;font-size:12px;padding:5px 8px;border-radius:6px;border:1px solid #d1d5db;background:#fff;color:#1a1a2e;outline:none;min-width:0}
.filter-input:focus{border-color:#6b7280}
.filter-clear{font-size:11px;color:#9ca3af;cursor:pointer;background:none;border:none;padding:3px 5px;border-radius:4px;flex-shrink:0;font-family:inherit}
.filter-tags{display:flex;flex-wrap:wrap;gap:4px;margin-top:5px}
.ftag{font-size:10px;padding:2px 8px;border-radius:10px;background:#1a1a2e;color:#fff;display:flex;align-items:center;gap:4px;cursor:pointer}
.ftag-x{font-size:10px;opacity:.6}
.filter-count{font-size:10px;color:#6b7280;margin-top:4px}
.pcard.dimmed{opacity:.25;pointer-events:none}
.pcard.matched .pname{color:#1d4ed8}
mark{background:#fef08a;color:inherit;border-radius:2px;padding:0 1px}
.rscroll{flex:1;overflow-y:auto;padding:10px 13px}
.pcard{border:1px solid #eaecf0;border-radius:9px;padding:9px 11px;margin-bottom:7px;cursor:pointer;transition:all .15s}
.pcard:hover{border-color:#9ca3af;background:#fafbfc}
.pcard.hi{border-color:#1d4ed8;background:#eff6ff}
.ptop{display:flex;align-items:flex-start;justify-content:space-between;gap:6px;margin-bottom:2px}
.pname{font-size:12px;font-weight:600;color:#1a1a2e;line-height:1.3}
.ptyp{font-size:9px;padding:2px 5px;border-radius:5px;background:#f1f5f9;color:#475569;font-weight:500;white-space:nowrap;flex-shrink:0}
.pmeta{font-size:11px;color:#6b7280;margin-top:2px;line-height:1.4}
.pdist{font-size:10px;color:#9ca3af;margin-top:2px}
.pdot{display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:4px;vertical-align:middle}
.nores{font-size:12px;color:#9ca3af;font-style:italic;text-align:center;padding:20px 10px}
.aifooter{padding:10px 13px;border-top:1px solid #eaecf0;background:#fafbfc;flex-shrink:0}
.aiinner{font-size:12px;color:#374151;line-height:1.65;padding:9px 11px;background:#fff;border-radius:8px;border:1px solid #eaecf0;min-height:42px;max-height:110px;overflow-y:auto}
.aiinner b{color:#1a1a2e;font-weight:600}

/* REVIEWER tab */
.rev-header{padding:11px 13px;border-bottom:1px solid #eaecf0;flex-shrink:0}
.rev-scroll{flex:1;overflow-y:auto;padding:10px 13px}
.rev-card{border:1px solid #eaecf0;border-radius:9px;padding:10px 12px;margin-bottom:8px;background:#fff}
.rev-card-top{display:flex;align-items:flex-start;justify-content:space-between;gap:6px;margin-bottom:4px}
.rev-place-name{font-size:13px;font-weight:600;color:#1a1a2e}
.rev-stars{color:#f59e0b;font-size:13px;letter-spacing:1px}
.rev-meta{font-size:10px;color:#9ca3af;margin-bottom:5px}
.rev-text{font-size:12px;color:#374151;line-height:1.55}
.rev-tags{display:flex;flex-wrap:wrap;gap:4px;margin-top:6px}
.rev-tag{font-size:9px;padding:2px 7px;border-radius:8px;background:#f1f5f9;color:#475569}
.rev-actions{display:flex;gap:6px;margin-top:6px}
.rev-act-btn{font-size:10px;padding:3px 9px;border-radius:6px;border:1px solid #e5e7eb;background:#f9fafb;color:#374151;cursor:pointer;font-family:inherit}
.rev-act-btn:hover{background:#f3f4f6;border-color:#9ca3af}
.rev-act-btn.del{color:#ef4444;border-color:#fecaca}
.rev-act-btn.del:hover{background:#fef2f2}
.add-btn-wrap{padding:10px 13px;border-top:1px solid #eaecf0;flex-shrink:0}
.add-location-btn{width:100%;font-family:inherit;font-size:12px;font-weight:600;padding:9px;border-radius:8px;border:1.5px dashed #d1d5db;background:#fafbfc;color:#374151;cursor:pointer;transition:all .15s}
.add-location-btn:hover{border-color:#9ca3af;background:#f3f4f6}
.no-reviews{font-size:12px;color:#9ca3af;font-style:italic;text-align:center;padding:24px 10px}

/* ADD/EDIT modal */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:1000;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:#fff;border-radius:14px;padding:20px;width:340px;max-width:92vw;max-height:90vh;overflow-y:auto;box-shadow:0 8px 32px rgba(0,0,0,.18)}
.modal-title{font-size:15px;font-weight:700;margin-bottom:14px;color:#1a1a2e}
.form-group{margin-bottom:11px}
.form-label{font-size:11px;font-weight:600;color:#374151;margin-bottom:4px;display:block}
.form-input{width:100%;font-family:inherit;font-size:12px;padding:7px 10px;border-radius:8px;border:1px solid #d1d5db;background:#fff;color:#1a1a2e;outline:none}
.form-input:focus{border-color:#6b7280}
textarea.form-input{resize:vertical;min-height:64px}
.star-picker{display:flex;gap:4px;margin-top:2px}
.star-btn{font-size:20px;cursor:pointer;opacity:.3;transition:opacity .1s;background:none;border:none;padding:0;line-height:1}
.star-btn.lit{opacity:1}
.tag-input-row{display:flex;gap:6px}
.tag-chips{display:flex;flex-wrap:wrap;gap:4px;margin-top:5px}
.tag-chip{font-size:10px;padding:2px 8px;border-radius:8px;background:#1a1a2e;color:#fff;cursor:pointer}
.modal-actions{display:flex;gap:8px;margin-top:16px}
.modal-save{flex:1;font-family:inherit;font-size:12px;font-weight:700;padding:9px;border-radius:8px;border:none;background:#1a1a2e;color:#fff;cursor:pointer}
.modal-save:hover{opacity:.86}
.modal-cancel{flex:1;font-family:inherit;font-size:12px;font-weight:500;padding:9px;border-radius:8px;border:1px solid #d1d5db;background:#fff;color:#374151;cursor:pointer}
.modal-cancel:hover{background:#f9fafb}

@keyframes spin{to{transform:rotate(360deg)}}
.spin{display:inline-block;width:11px;height:11px;border:1.5px solid #d1d5db;border-top-color:#6b7280;border-radius:50%;animation:spin .6s linear infinite;vertical-align:middle;margin-right:5px}
.maplibregl-popup-content{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:12px;padding:10px 12px;border-radius:8px;min-width:160px;max-width:230px;line-height:1.5}
.maplibregl-popup-content b{font-size:13px;display:block;margin-bottom:3px}
.ptyplabel{display:inline-block;font-size:9px;padding:1px 6px;border-radius:4px;background:#f1f5f9;color:#475569;margin-bottom:4px}
.pmeta-popup{font-size:11px;color:#6b7280}
@media(max-width:800px){.body{grid-template-columns:1fr}.side,.maincol{border-right:none;border-bottom:1px solid #eaecf0}.rpanel{max-height:420px}}
</style>
</head>
<body>

<!-- Add/Edit modal -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <div class="modal-title" id="modalTitle">Add location review</div>
    <div class="form-group">
      <label class="form-label">Place name *</label>
      <input class="form-input" id="fName" placeholder="e.g. Blue Bottle Coffee"/>
    </div>
    <div class="form-group">
      <label class="form-label">Type / category</label>
      <input class="form-input" id="fType" placeholder="cafe, park, restaurantвҖҰ"/>
    </div>
    <div class="form-group">
      <label class="form-label">Address</label>
      <input class="form-input" id="fAddr" placeholder="123 Main St, City"/>
    </div>
    <div class="form-group">
      <label class="form-label">Rating</label>
      <div class="star-picker" id="starPicker">
        <button class="star-btn" data-v="1" onclick="setStar(1)">вҳ…</button>
        <button class="star-btn" data-v="2" onclick="setStar(2)">вҳ…</button>
        <button class="star-btn" data-v="3" onclick="setStar(3)">вҳ…</button>
        <button class="star-btn" data-v="4" onclick="setStar(4)">вҳ…</button>
        <button class="star-btn" data-v="5" onclick="setStar(5)">вҳ…</button>
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">Your review</label>
      <textarea class="form-input" id="fReview" placeholder="What did you think? What's it good for?"></textarea>
    </div>
    <div class="form-group">
      <label class="form-label">Tags (press Enter to add)</label>
      <div class="tag-input-row">
        <input class="form-input" id="fTagInput" placeholder="outdoor, vegan, family-friendlyвҖҰ" onkeydown="if(event.key==='Enter'){event.preventDefault();addTag()}"/>
      </div>
      <div class="tag-chips" id="fTags"></div>
    </div>
    <div class="form-group">
      <label class="form-label">Website (optional)</label>
      <input class="form-input" id="fWeb" placeholder="https://вҖҰ"/>
    </div>
    <div class="modal-actions">
      <button class="modal-cancel" onclick="closeModal()">Cancel</button>
      <button class="modal-save" onclick="saveReview()">Save review</button>
    </div>
  </div>
</div>

<div class="app">
  <div class="topbar">
    <div class="dot busy" id="dot"></div>
    <span id="statusText">Getting your locationвҖҰ</span>
    <span id="coordsText">вҖ”</span>
  </div>
  <div class="body">

    <!-- LEFT: weather + nearby + hover panel -->
    <div class="side">
      <div class="sec">
        <div class="stitle">Current conditions</div>
        <div id="weatherPanel"><span class="ghost" style="font-size:12px">Waiting for GPSвҖҰ</span></div>
      </div>
      <div class="sec" style="flex:1;overflow-y:auto">
        <div class="stitle">Nearby cities В· tap to search</div>
        <div id="nearbyPanel"><span class="ghost" style="font-size:12px">LoadingвҖҰ</span></div>
      </div>
      <!-- hover preview panel -->
      <div class="hover-panel" id="hoverPanel">
        <div class="hover-city-name" id="hoverCityName"></div>
        <div class="hover-activities" id="hoverActivities"><span class="spin"></span></div>
      </div>
    </div>

    <!-- CENTER: map -->
    <div class="maincol">
      <div id="map"></div>
      <div class="attr-bar">
        <div class="legend">
          <div class="li"><div class="ld" style="background:#1d4ed8;outline:2px solid #1d4ed8;outline-offset:1px"></div>You</div>
          <div class="li"><div style="background:#fff;border:2px solid #16a34a;border-radius:4px;padding:1px 4px;font-size:9px;font-weight:700;color:#16a34a">72В° City</div></div>
          <div class="li"><div class="ld" style="background:#e11d48"></div>Food</div>
          <div class="li"><div class="ld" style="background:#16a34a"></div>Nature</div>
          <div class="li"><div class="ld" style="background:#7c3aed"></div>Culture</div>
          <div class="li"><div class="ld" style="background:#0891b2"></div>Other</div>
        </div>
        <div class="attr-text">
          В© <a href="https://openfreemap.org" target="_blank">OpenFreeMap</a>
          В© <a href="https://openmaptiles.org/" target="_blank">OpenMapTiles</a>
          В© <a href="https://openstreetmap.org/copyright" target="_blank">OpenStreetMap</a>
        </div>
      </div>
      <div class="btmpanel">
        <div class="stitle" style="margin-bottom:6px">AI route advisor</div>
        <div class="brow">
          <button id="aiBtn" onclick="runAI()" disabled>вңҰ Analyze &amp; recommend</button>
          <button id="refreshBtn" onclick="startTracking()" disabled>вҶә Refresh</button>
        </div>
        <div class="aibox" id="aiBox"><span class="ghost">Allow location access to get personalized travel advice.</span></div>
      </div>
    </div>

    <!-- RIGHT: tabs вҖ” Search | Reviews -->
    <div class="rpanel">
      <div class="rtabs">
        <div class="rtab active" onclick="switchTab('search',this)">рҹ”Қ Search</div>
        <div class="rtab" onclick="switchTab('reviews',this)">вӯҗ My Reviews</div>
      </div>

      <!-- SEARCH TAB -->
      <div class="tab-pane active" id="tab-search">
        <div class="rheader">
          <div class="srow">
            <input class="sinput" id="searchInput" type="text" placeholder="cafes, parks, museumsвҖҰ" onkeydown="if(event.key==='Enter')doSearch()"/>
            <button class="sbtn" id="searchBtn" onclick="doSearch()" disabled>Search</button>
          </div>
          <div class="chips">
            <span class="chip" onclick="chipClick(this,'restaurants')">рҹҚҪ Eat</span>
            <span class="chip" onclick="chipClick(this,'parks')">рҹҢі Parks</span>
            <span class="chip" onclick="chipClick(this,'cafes')">вҳ• Cafes</span>
            <span class="chip" onclick="chipClick(this,'museums')">рҹҸӣ Culture</span>
            <span class="chip" onclick="chipClick(this,'hiking')">рҹҘҫ Hiking</span>
            <span class="chip" onclick="chipClick(this,'bars')">рҹҚә Bars</span>
            <span class="chip" onclick="chipClick(this,'shopping')">рҹӣҚ Shopping</span>
            <span class="chip" onclick="chipClick(this,'beaches')">рҹҸ– Beaches</span>
          </div>
        </div>
        <div class="radius-bar">
          <div class="radius-row">
            <span class="radius-label">рҹ“Қ Radius:</span>
            <input class="radius-slider" id="radiusSlider" type="range" min="0.25" max="25" step="0.25" value="2" oninput="onRadiusSlide(this.value)"/>
            <span class="radius-val" id="radiusVal">2 mi</span>
          </div>
          <div class="radius-presets">
            <span class="rpill" onclick="setRadius(0.5,this)">0.5 mi</span>
            <span class="rpill on" onclick="setRadius(2,this)">2 mi</span>
            <span class="rpill" onclick="setRadius(5,this)">5 mi</span>
            <span class="rpill" onclick="setRadius(10,this)">10 mi</span>
            <span class="rpill" onclick="setRadius(25,this)">25 mi</span>
          </div>
        </div>
        <div class="filter-bar" id="filterBar">
          <div class="filter-row">
            <span class="filter-icon">рҹ”Қ Filter:</span>
            <input class="filter-input" id="filterInput" type="text" placeholder="outdoor, wifi, veganвҖҰ" oninput="onFilterInput()"/>
